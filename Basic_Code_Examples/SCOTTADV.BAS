10 REM *** SCOTT ADAMS ADVENTURE INTERPRETER ***
11 REM *** FOR TRS-80 LEVEL II BASIC ***
12 REM *** READS SCOTTFREE .DAT FORMAT ***
13 REM *** VIA TAPE I/O (INPUT#-1) ***
20 CLS
30 PRINT "=================================="
31 PRINT "  SCOTT ADAMS ADVENTURE DRIVER"
32 PRINT "  FOR TRS-80 LEVEL II BASIC"
33 PRINT "=================================="
34 PRINT
35 PRINT "LOAD YOUR .DAT ADVENTURE FILE"
36 PRINT "USING THE LOAD TAPE BUTTON FIRST,"
37 PRINT "THEN PRESS ENTER TO BEGIN."
38 PRINT
40 INPUT K$
50 DD=0: DF=1: CF=0: CC=0
51 N$="": V$="": W$=""
52 LP=0: L$=""
53 QT$=CHR$(34)
60 GOTO 100
100 REM ========================================
101 REM  READ GAME DATA FROM TAPE
102 REM ========================================
103 GOSUB 3300: H0=TV
104 GOSUB 3300: NI=TV
105 GOSUB 3300: NA=TV
106 GOSUB 3300: NW=TV
107 GOSUB 3300: NR=TV
108 GOSUB 3300: MX=TV
109 GOSUB 3300: SR=TV
110 GOSUB 3300: NT=TV
111 GOSUB 3300: WL=TV
112 GOSUB 3300: LT=TV: OL=LT
113 GOSUB 3300: MM=TV
114 GOSUB 3300: TR=TV
120 REM *** DIMENSION ARRAYS ***
121 DIM AC((NA+1)*8)
122 DIM EX((NR+1)*6)
123 DIM IL(NI): DIM IS(NI)
124 DIM VB$(NW): DIM NN$(NW)
125 DIM RD$(NR): DIM MS$(MM)
126 DIM ID$(NI): DIM IG$(NI)
127 DIM FL(31): DIM CT(15): DIM SV(15)
128 DIM PP(7)
129 PRINT "LOADING";
140 REM *** READ ACTION TABLE ***
141 FOR I=0 TO NA
142 FOR J=0 TO 7
143 GOSUB 3300: AC(I*8+J)=TV
144 NEXT J
145 NEXT I
146 PRINT ".";
150 REM *** READ VOCABULARY ***
151 FOR I=0 TO NW
152 GOSUB 3300: VB$(I)=T$
153 GOSUB 3300: NN$(I)=T$
154 NEXT I
155 PRINT ".";
160 REM *** READ ROOMS ***
161 FOR I=0 TO NR
162 FOR J=0 TO 5
163 GOSUB 3300: EX(I*6+J)=TV
164 NEXT J
165 GOSUB 3300: RD$(I)=T$
166 NEXT I
167 PRINT ".";
170 REM *** READ MESSAGES ***
171 FOR I=0 TO MM
172 GOSUB 3300: MS$(I)=T$
173 NEXT I
174 PRINT ".";
180 REM *** READ ITEMS ***
181 FOR I=0 TO NI
182 GOSUB 3300: ID$(I)=T$
183 GOSUB 3300: IL(I)=TV: IS(I)=TV
184 NEXT I
185 PRINT ".";
190 REM *** SKIP ACTION COMMENTS ***
191 FOR I=0 TO NA
192 GOSUB 3300
193 NEXT I
194 PRINT ".";
195 REM *** READ TRAILER ***
196 GOSUB 3300: VN=TV
197 GOSUB 3300
198 PRINT " DONE!"
500 REM ========================================
501 REM  POST-LOAD SETUP
502 REM ========================================
503 REM *** EXTRACT AUTOGET WORDS ***
504 FOR I=0 TO NI
505 IG$(I)=""
506 D$=ID$(I)
507 IF LEN(D$)<3 THEN GOTO 516
508 IF RIGHT$(D$,1)<>"/" THEN GOTO 516
509 FOR J=LEN(D$)-1 TO 1 STEP -1
510 IF MID$(D$,J,1)="/" THEN IG$(I)=MID$(D$,J+1,LEN(D$)-J-1): J=1
511 NEXT J
516 NEXT I
520 REM *** INITIALIZE PLAYER STATE ***
521 RM=SR: DD=0: DF=1: CF=0: CC=0
522 FOR I=0 TO 31: FL(I)=0: NEXT I
523 FOR I=0 TO 15: CT(I)=0: SV(I)=0: NEXT I
530 CLS
531 PRINT "ADVENTURE LOADED!"
532 PRINT "TYPE 'HELP' FOR COMMANDS."
533 PRINT
534 GOTO 1000
1000 REM ========================================
1001 REM  MAIN GAME LOOP
1002 REM ========================================
1003 IF DD=1 THEN PRINT: PRINT "THE GAME IS OVER.": END
1004 REM *** LIGHT HANDLING ***
1005 IF NI<9 THEN GOTO 1012
1006 IF IL(9)<>-1 AND IL(9)<>RM THEN GOTO 1012
1007 IF LT<1 THEN GOTO 1012
1008 LT=LT-1
1009 IF LT=0 THEN FL(16)=1: PRINT "LIGHT HAS RUN OUT!"
1010 IF LT>0 AND LT<25 THEN PRINT "LIGHT RUNS OUT IN";LT;"TURNS!"
1012 REM *** DISPLAY ROOM ***
1013 IF DF=1 THEN GOSUB 2600: DF=0
1015 REM *** RUN AUTO-ACTIONS ***
1016 VB=0: NO=0: GOSUB 1400
1017 IF DF=1 THEN GOSUB 2600: DF=0
1020 REM *** GET PLAYER INPUT ***
1021 PRINT
1022 INPUT "WHAT SHALL I DO? ";I$
1023 IF I$="" THEN GOTO 1000
1025 REM *** PARSE INPUT ***
1026 GOSUB 1200
1027 IF VB<0 THEN GOTO 1050
1030 REM *** TRY ACTION TABLE ***
1031 MF=0: GOSUB 1400
1032 IF MF=1 THEN GOTO 1050
1035 REM *** BUILT-IN FALLBACKS ***
1036 IF VB=1 AND NO>=1 AND NO<=6 THEN GOSUB 3000: GOTO 1050
1037 IF VB=10 THEN GOSUB 3050: GOTO 1050
1038 IF VB=18 THEN GOSUB 3100: GOTO 1050
1039 PRINT "I DON'T UNDERSTAND YOUR COMMAND."
1050 REM *** REDRAW IF NEEDED ***
1051 IF DF=1 THEN GOSUB 2600: DF=0
1060 GOTO 1000
1200 REM ========================================
1201 REM  INPUT PARSING
1202 REM ========================================
1203 REM *** UPPERCASE ***
1204 U$=""
1205 FOR J=1 TO LEN(I$)
1206 C=ASC(MID$(I$,J,1))
1207 IF C>=97 AND C<=122 THEN C=C-32
1208 U$=U$+CHR$(C)
1209 NEXT J
1210 I$=U$
1212 REM *** EXPAND SHORTCUTS ***
1213 IF I$="N" THEN I$="GO NORTH"
1214 IF I$="S" THEN I$="GO SOUTH"
1215 IF I$="E" THEN I$="GO EAST"
1216 IF I$="W" THEN I$="GO WEST"
1217 IF I$="U" THEN I$="GO UP"
1218 IF I$="D" THEN I$="GO DOWN"
1219 IF I$="I" THEN I$="INVENTORY"
1220 IF I$="L" THEN I$="LOOK"
1222 REM *** SPECIAL COMMANDS ***
1223 IF I$="INVENTORY" THEN GOSUB 2800: VB=-1: RETURN
1224 IF I$="LOOK" THEN DF=1: VB=-1: RETURN
1225 IF I$="SCORE" THEN GOSUB 2900: VB=-1: RETURN
1226 IF I$="HELP" THEN GOSUB 1280: VB=-1: RETURN
1227 IF I$="QUIT" OR I$="EXIT" THEN DD=1: VB=-1: RETURN
1230 REM *** SPLIT INTO VERB AND NOUN ***
1231 V$="": W$=""
1232 P=INSTR(I$," ")
1233 IF P=0 THEN V$=I$: GOTO 1240
1234 V$=LEFT$(I$,P-1): W$=MID$(I$,P+1)
1236 IF LEN(W$)>0 AND LEFT$(W$,1)=" " THEN W$=MID$(W$,2): GOTO 1236
1240 REM *** LOOK UP VERB ***
1241 F$=V$: GOSUB 1300: VB=FW
1242 IF VB>=0 THEN GOTO 1250
1243 REM VERB NOT FOUND - TRY AS DIRECTION
1244 IF W$<>"" THEN PRINT "I DON'T KNOW WHAT '";V$;"' MEANS.": VB=-1: RETURN
1245 F$=V$: GOSUB 1350
1246 IF FW>=1 AND FW<=6 THEN VB=1: NO=FW: N$=V$: RETURN
1247 PRINT "I DON'T KNOW WHAT '";V$;"' MEANS.": VB=-1: RETURN
1250 REM *** LOOK UP NOUN ***
1251 IF W$="" THEN NO=0: RETURN
1252 F$=W$: GOSUB 1350: NO=FW
1253 IF NO=-1 THEN PRINT "I DON'T KNOW WHAT '";W$;"' MEANS.": VB=-1: RETURN
1254 N$=W$: RETURN
1280 REM *** HELP ***
1281 PRINT "COMMANDS: N S E W U D"
1282 PRINT "INVENTORY, LOOK, SCORE"
1283 PRINT "GET <ITEM>, DROP <ITEM>"
1284 PRINT "QUIT, SAVE"
1285 RETURN
1300 REM ========================================
1301 REM  FIND VERB
1302 REM  INPUT: F$  OUTPUT: FW (GROUP# OR -1)
1303 REM ========================================
1304 FW=-1: S$=LEFT$(F$,WL)
1305 IF S$="" THEN RETURN
1306 G=-1
1307 FOR K=0 TO NW
1308 E$=VB$(K)
1309 IF LEFT$(E$,1)="*" THEN E$=MID$(E$,2): GOTO 1313
1310 G=K
1313 IF LEFT$(E$,WL)=S$ THEN FW=G: K=NW
1314 NEXT K
1315 RETURN
1350 REM ========================================
1351 REM  FIND NOUN
1352 REM  INPUT: F$  OUTPUT: FW (GROUP# OR -1)
1353 REM ========================================
1354 FW=-1: S$=LEFT$(F$,WL)
1355 IF S$="" THEN RETURN
1356 G=-1
1357 FOR K=0 TO NW
1358 E$=NN$(K)
1359 IF LEFT$(E$,1)="*" THEN E$=MID$(E$,2): GOTO 1363
1360 G=K
1363 IF LEFT$(E$,WL)=S$ THEN FW=G: K=NW
1364 NEXT K
1365 RETURN
1400 REM ========================================
1401 REM  ACTION PROCESSING
1402 REM  INPUT: VB=VERB, NO=NOUN
1403 REM  OUTPUT: MF=1 IF MATCHED
1404 REM ========================================
1405 MF=0: CF=0
1406 FOR AI=0 TO NA
1407 AB=AI*8
1408 AV=INT(AC(AB)/150)
1409 AN=AC(AB) MOD 150
1410 IF VB=0 THEN GOTO 1420
1411 REM *** PLAYER ACTION ***
1412 IF AV=0 THEN GOTO 1490
1413 IF AV<>VB THEN GOTO 1490
1414 IF AN<>0 AND AN<>NO THEN GOTO 1490
1415 GOTO 1440
1420 REM *** AUTO-ACTION ***
1421 IF AV<>0 THEN CF=0: GOTO 1490
1422 IF CF=0 AND AN>0 THEN IF RND(100)>AN THEN GOTO 1490
1440 REM *** CHECK 5 CONDITIONS ***
1441 OK=1: PN=0
1442 FOR CI=1 TO 5
1443 CD=AC(AB+CI) MOD 20
1444 CV=INT(AC(AB+CI)/20)
1445 IF CD=0 THEN PP(PN)=CV: PN=PN+1: GOTO 1450
1446 GOSUB 2000
1447 IF CR=0 THEN OK=0: CI=5
1450 NEXT CI
1451 CF=0
1452 IF OK=0 THEN GOTO 1490
1453 MF=1
1460 REM *** DECODE 4 SUB-ACTIONS ***
1461 PI=0
1462 S1=INT(AC(AB+6)/150)
1463 S2=AC(AB+6) MOD 150
1464 S3=INT(AC(AB+7)/150)
1465 S4=AC(AB+7) MOD 150
1466 OP=S1: IF OP<>0 THEN GOSUB 1500
1467 OP=S2: IF OP<>0 THEN GOSUB 1500
1468 OP=S3: IF OP<>0 THEN GOSUB 1500
1469 OP=S4: IF OP<>0 THEN GOSUB 1500
1480 IF CF=1 THEN GOTO 1490
1481 IF VB<>0 THEN AI=NA
1490 NEXT AI
1495 RETURN
1500 REM *** EXECUTE ONE SUB-ACTION ***
1501 IF OP>=1 AND OP<=51 THEN PRINT MS$(OP): RETURN
1502 IF OP>=102 THEN PRINT MS$(OP-50): RETURN
1503 IF OP=73 THEN CF=1: RETURN
1504 IF OP>=52 AND OP<=87 THEN GOSUB 2200: RETURN
1505 RETURN
2000 REM ========================================
2001 REM  CONDITION CHECKER
2002 REM  INPUT: CD (1-19), CV (VALUE)
2003 REM  OUTPUT: CR (1=TRUE, 0=FALSE)
2004 REM ========================================
2005 CR=0
2006 ON CD GOTO 2010,2012,2014,2016,2018,2020,2022,2024,2026,2028,2033,2038,2040,2042,2044,2046,2048,2050,2052
2007 RETURN
2010 IF IL(CV)=-1 THEN CR=1
2011 RETURN
2012 IF IL(CV)=RM THEN CR=1
2013 RETURN
2014 IF IL(CV)=-1 OR IL(CV)=RM THEN CR=1
2015 RETURN
2016 IF RM=CV THEN CR=1
2017 RETURN
2018 IF IL(CV)<>RM THEN CR=1
2019 RETURN
2020 IF IL(CV)<>-1 THEN CR=1
2021 RETURN
2022 IF RM<>CV THEN CR=1
2023 RETURN
2024 IF FL(CV)<>0 THEN CR=1
2025 RETURN
2026 IF FL(CV)=0 THEN CR=1
2027 RETURN
2028 REM CD10: CARRYING SOMETHING
2029 FOR CK=0 TO NI: IF IL(CK)=-1 THEN CR=1: CK=NI
2030 NEXT CK
2031 RETURN
2033 REM CD11: CARRYING NOTHING
2034 CR=1
2035 FOR CK=0 TO NI: IF IL(CK)=-1 THEN CR=0: CK=NI
2036 NEXT CK
2037 RETURN
2038 IF IL(CV)<>-1 AND IL(CV)<>RM THEN CR=1
2039 RETURN
2040 IF IL(CV)<>0 THEN CR=1
2041 RETURN
2042 IF IL(CV)=0 THEN CR=1
2043 RETURN
2044 IF CT(CC)<=CV THEN CR=1
2045 RETURN
2046 IF CT(CC)>CV THEN CR=1
2047 RETURN
2048 IF IL(CV)=IS(CV) THEN CR=1
2049 RETURN
2050 IF IL(CV)<>IS(CV) THEN CR=1
2051 RETURN
2052 IF CT(CC)=CV THEN CR=1
2053 RETURN
2200 REM ========================================
2201 REM  OPCODE EXECUTION (52-87)
2202 REM  INPUT: OP, PP(), PI
2203 REM ========================================
2204 ON OP-51 GOTO 2210,2230,2250,2260,2270,2275,2280,2285,2290,2295,2300,2310,2315,2320,2325,2330,2335,2340,2345,2350,2355,2360,2365,2370,2375,2380,2385,2390,2395,2400,2405,2410,2415,2420,2425,2430
2205 RETURN
2210 REM *** OP52: AUTO-GET BY NOUN ***
2211 S$=LEFT$(N$,WL)
2212 FOR GI=0 TO NI
2213 IF IG$(GI)="" THEN GOTO 2225
2214 IF LEFT$(IG$(GI),WL)<>S$ THEN GOTO 2225
2215 IF IL(GI)<>RM THEN GOTO 2225
2216 C2=0: FOR CK=0 TO NI: IF IL(CK)=-1 THEN C2=C2+1
2217 NEXT CK
2218 IF C2>=MX THEN PRINT "I'VE TOO MUCH TO CARRY!": RETURN
2219 IL(GI)=-1: PRINT "OK": RETURN
2225 NEXT GI
2226 PRINT "I DON'T SEE IT HERE.": RETURN
2230 REM *** OP53: AUTO-DROP BY NOUN ***
2231 S$=LEFT$(N$,WL)
2232 FOR GI=0 TO NI
2233 IF IG$(GI)="" THEN GOTO 2245
2234 IF LEFT$(IG$(GI),WL)<>S$ THEN GOTO 2245
2235 IF IL(GI)<>-1 THEN GOTO 2245
2236 IL(GI)=RM: PRINT "OK": RETURN
2245 NEXT GI
2246 PRINT "I'M NOT CARRYING IT.": RETURN
2250 REM *** OP54: MOVE TO ROOM ***
2251 RM=PP(PI): PI=PI+1: DF=1: RETURN
2260 REM *** OP55: DESTROY ITEM ***
2261 IL(PP(PI))=0: PI=PI+1: RETURN
2270 REM *** OP56: SET DARK ***
2271 FL(15)=1: RETURN
2275 REM *** OP57: CLEAR DARK ***
2276 FL(15)=0: RETURN
2280 REM *** OP58: SET FLAG ***
2281 FL(PP(PI))=1: PI=PI+1: RETURN
2285 REM *** OP59: DESTROY ITEM ***
2286 IL(PP(PI))=0: PI=PI+1: RETURN
2290 REM *** OP60: CLEAR FLAG ***
2291 FL(PP(PI))=0: PI=PI+1: RETURN
2295 REM *** OP61: DIE ***
2296 PRINT "I'M DEAD..."
2297 RM=NR: FL(15)=0: DF=1: RETURN
2300 REM *** OP62: PUT ITEM IN ROOM ***
2301 IL(PP(PI))=PP(PI+1): PI=PI+2: RETURN
2310 REM *** OP63: GAME OVER ***
2311 DD=1: RETURN
2315 REM *** OP64: LOOK ***
2316 DF=1: RETURN
2320 REM *** OP65: SCORE ***
2321 GOSUB 2900: RETURN
2325 REM *** OP66: INVENTORY ***
2326 GOSUB 2800: RETURN
2330 REM *** OP67: SET FLAG 0 ***
2331 FL(0)=1: RETURN
2335 REM *** OP68: CLEAR FLAG 0 ***
2336 FL(0)=0: RETURN
2340 REM *** OP69: REFILL LAMP ***
2341 LT=OL: RETURN
2345 REM *** OP70: CLEAR SCREEN ***
2346 CLS: RETURN
2350 REM *** OP71: SAVE GAME ***
2351 GOSUB 3200: RETURN
2355 REM *** OP72: SWAP TWO ITEMS ***
2356 T=IL(PP(PI)): IL(PP(PI))=IL(PP(PI+1)): IL(PP(PI+1))=T: PI=PI+2: RETURN
2360 REM *** OP73: CONTINUE ***
2361 CF=1: RETURN
2365 REM *** OP74: SUPERGET ***
2366 IL(PP(PI))=-1: PI=PI+1: RETURN
2370 REM *** OP75: PUT ITEM WITH ***
2371 IL(PP(PI))=IL(PP(PI+1)): PI=PI+2: RETURN
2375 REM *** OP76: LOOK (IMMEDIATE) ***
2376 GOSUB 2600: RETURN
2380 REM *** OP77: DEC COUNTER ***
2381 CT(CC)=CT(CC)-1: RETURN
2385 REM *** OP78: PRINT COUNTER ***
2386 PRINT CT(CC);: RETURN
2390 REM *** OP79: SET COUNTER ***
2391 CT(CC)=PP(PI): PI=PI+1: RETURN
2395 REM *** OP80: SWAP LOC/SAVED ***
2396 T=RM: RM=SV(CC): SV(CC)=T: DF=1: RETURN
2400 REM *** OP81: SELECT COUNTER ***
2401 CC=PP(PI): PI=PI+1: RETURN
2405 REM *** OP82: ADD TO COUNTER ***
2406 CT(CC)=CT(CC)+PP(PI): PI=PI+1: RETURN
2410 REM *** OP83: SUB FROM COUNTER ***
2411 CT(CC)=CT(CC)-PP(PI): PI=PI+1: RETURN
2415 REM *** OP84: PRINT NOUN ***
2416 PRINT N$;: RETURN
2420 REM *** OP85: PRINT NOUN+NL ***
2421 PRINT N$: RETURN
2425 REM *** OP86: NEWLINE ***
2426 PRINT: RETURN
2430 REM *** OP87: SWAP LOC/SPECIFIC ***
2431 T=RM: RM=SV(PP(PI)): SV(PP(PI))=T: PI=PI+1: DF=1: RETURN
2600 REM ========================================
2601 REM  LOOK SUBROUTINE
2602 REM ========================================
2603 IF FL(15)=0 THEN GOTO 2610
2604 REM DARK - CHECK IF LIT
2605 IF NI>=9 AND (IL(9)=-1 OR IL(9)=RM) THEN GOTO 2610
2606 PRINT "I CAN'T SEE. IT IS TOO DARK!"
2607 RETURN
2610 REM *** ROOM DESCRIPTION ***
2611 D$=RD$(RM)
2612 IF D$="" THEN GOTO 2630
2613 IF LEFT$(D$,1)="*" THEN PRINT MID$(D$,2): GOTO 2630
2614 PRINT "I'M IN A ";D$
2630 REM *** LIST ITEMS HERE ***
2631 F=0
2632 FOR VI=0 TO NI
2633 IF IL(VI)<>RM THEN GOTO 2650
2635 D$=ID$(VI)
2636 P=INSTR(D$,"/")
2637 IF P>0 THEN D$=LEFT$(D$,P-1)
2640 IF LEN(D$)>0 AND RIGHT$(D$,1)=" " THEN D$=LEFT$(D$,LEN(D$)-1): GOTO 2640
2641 IF D$="" THEN GOTO 2650
2643 IF F=0 THEN PRINT "I CAN ALSO SEE:";
2644 IF F>0 THEN PRINT " -";
2645 PRINT " ";D$;
2646 F=F+1
2650 NEXT VI
2651 IF F>0 THEN PRINT
2660 REM *** LIST EXITS ***
2661 PRINT "OBVIOUS EXITS: ";
2662 F=0
2663 FOR DI=0 TO 5
2664 IF EX(RM*6+DI)=0 THEN GOTO 2680
2665 IF F>0 THEN PRINT ", ";
2666 ON DI+1 GOTO 2670,2671,2672,2673,2674,2675
2670 PRINT "NORTH";: GOTO 2676
2671 PRINT "SOUTH";: GOTO 2676
2672 PRINT "EAST";: GOTO 2676
2673 PRINT "WEST";: GOTO 2676
2674 PRINT "UP";: GOTO 2676
2675 PRINT "DOWN";: GOTO 2676
2676 F=F+1
2680 NEXT DI
2685 IF F=0 THEN PRINT "NONE";
2686 PRINT
2690 RETURN
2800 REM ========================================
2801 REM  INVENTORY SUBROUTINE
2802 REM ========================================
2803 PRINT "I'M CARRYING:";
2804 F=0
2805 FOR II=0 TO NI
2806 IF IL(II)<>-1 THEN GOTO 2816
2807 D$=ID$(II)
2808 P=INSTR(D$,"/")
2809 IF P>0 THEN D$=LEFT$(D$,P-1)
2810 IF LEN(D$)>0 AND RIGHT$(D$,1)=" " THEN D$=LEFT$(D$,LEN(D$)-1): GOTO 2810
2811 IF F>0 THEN PRINT ",";
2812 PRINT " ";D$;
2813 F=F+1
2816 NEXT II
2817 IF F=0 THEN PRINT " NOTHING!";
2818 PRINT
2820 RETURN
2900 REM ========================================
2901 REM  SCORE SUBROUTINE
2902 REM ========================================
2903 SC=0
2904 FOR SI=0 TO NI
2905 IF LEFT$(ID$(SI),1)<>"*" THEN GOTO 2910
2906 IF IL(SI)<>TR THEN GOTO 2910
2907 SC=SC+1
2910 NEXT SI
2911 PRINT "I'VE STORED";SC;"TREASURES."
2912 IF NT>0 THEN PRINT "ON A SCALE OF 0 TO 100 THAT RATES";INT(SC*100/NT)
2913 IF SC=NT AND NT>0 THEN PRINT "WELL DONE!": DD=1
2920 RETURN
3000 REM ========================================
3001 REM  GO DIRECTION
3002 REM  INPUT: NO (1-6 = N/S/E/W/U/D)
3003 REM ========================================
3004 IF FL(15)=0 THEN GOTO 3010
3005 IF NI>=9 AND (IL(9)=-1 OR IL(9)=RM) THEN GOTO 3010
3006 IF RND(4)=1 THEN PRINT "I FELL AND BROKE MY NECK!": RM=NR: FL(15)=0: DF=1: RETURN
3007 PRINT "DANGEROUS TO MOVE IN THE DARK!"
3008 RETURN
3010 DR=NO-1
3011 IF EX(RM*6+DR)=0 THEN PRINT "I CAN'T GO IN THAT DIRECTION.": RETURN
3012 RM=EX(RM*6+DR): DF=1
3013 RETURN
3050 REM ========================================
3051 REM  GET ITEM
3052 REM ========================================
3053 IF W$="" THEN PRINT "WHAT?": RETURN
3054 S$=LEFT$(W$,WL)
3055 FOR GI=0 TO NI
3056 IF IG$(GI)="" THEN GOTO 3070
3057 IF LEFT$(IG$(GI),WL)<>S$ THEN GOTO 3070
3058 IF IL(GI)=RM THEN GOTO 3062
3059 IF IL(GI)=-1 THEN PRINT "I ALREADY HAVE IT.": RETURN
3060 GOTO 3070
3062 C2=0: FOR CK=0 TO NI: IF IL(CK)=-1 THEN C2=C2+1
3063 NEXT CK
3064 IF C2>=MX THEN PRINT "I'VE TOO MUCH TO CARRY!": RETURN
3065 IL(GI)=-1: PRINT "OK": RETURN
3070 NEXT GI
3071 PRINT "I DON'T SEE IT HERE.": RETURN
3100 REM ========================================
3101 REM  DROP ITEM
3102 REM ========================================
3103 IF W$="" THEN PRINT "WHAT?": RETURN
3104 S$=LEFT$(W$,WL)
3105 FOR GI=0 TO NI
3106 IF IG$(GI)="" THEN GOTO 3115
3107 IF LEFT$(IG$(GI),WL)<>S$ THEN GOTO 3115
3108 IF IL(GI)<>-1 THEN GOTO 3115
3109 IL(GI)=RM: PRINT "OK": RETURN
3115 NEXT GI
3116 PRINT "I'M NOT CARRYING IT.": RETURN
3200 REM ========================================
3201 REM  SAVE GAME (STUB)
3202 REM ========================================
3203 PRINT "SAVE IS NOT AVAILABLE."
3204 RETURN
3300 REM ========================================
3301 REM  TOKENIZER
3302 REM  READS NEXT TOKEN FROM TAPE FILE
3303 REM  OUTPUT: TT=0/TV=NUM OR TT=1/T$=STR
3304 REM ========================================
3305 IF LP<1 OR LP>LEN(L$) THEN GOTO 3330
3306 C$=MID$(L$,LP,1)
3307 IF C$=" " OR C$=CHR$(9) THEN LP=LP+1: GOTO 3305
3308 REM *** DISPATCH ON CHAR TYPE ***
3309 IF C$=QT$ THEN GOTO 3340
3310 IF C$>="0" AND C$<="9" THEN GOTO 3320
3311 IF C$="-" AND LP<LEN(L$) THEN IF MID$(L$,LP+1,1)>="0" AND MID$(L$,LP+1,1)<="9" THEN GOTO 3320
3312 LP=LP+1: GOTO 3305
3320 REM *** READ NUMBER TOKEN ***
3321 P1=LP
3322 IF C$="-" THEN LP=LP+1
3323 IF LP>LEN(L$) THEN GOTO 3327
3324 C$=MID$(L$,LP,1)
3325 IF C$>="0" AND C$<="9" THEN LP=LP+1: GOTO 3323
3327 TV=VAL(MID$(L$,P1,LP-P1)): TT=0
3328 RETURN
3330 REM *** READ NEXT LINE FROM TAPE ***
3331 INPUT#-1,L$
3332 LP=1
3333 GOTO 3305
3340 REM *** READ STRING TOKEN ***
3341 LP=LP+1: T$=""
3342 P=INSTR(LP,L$,QT$)
3343 IF P>0 THEN T$=MID$(L$,LP,P-LP): LP=P+1: TT=1: RETURN
3344 REM *** MULTI-LINE STRING ***
3345 IF LP<=LEN(L$) THEN T$=MID$(L$,LP)
3346 INPUT#-1,L$: LP=1
3347 P=INSTR(1,L$,QT$)
3348 IF P>0 THEN T$=T$+" "+LEFT$(L$,P-1): LP=P+1: TT=1: RETURN
3349 T$=T$+" "+L$
3350 GOTO 3346
