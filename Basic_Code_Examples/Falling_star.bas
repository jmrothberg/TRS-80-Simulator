10 CLS
20 PRINT "CATCH THE FALLING STARS!"
30 PRINT "A = LEFT   S = RIGHT"
40 PRINT "PRESS ANY KEY TO START"
50 IF INKEY$="" THEN 50
60 CLS
70 DIM S(10): DIM Y(10)
80 FOR I=1 TO 10:S(I)=0:Y(I)=0:NEXT I
90 B=960+32
100 SC=0
110 SP=400000
120 REM BASKET ROW 15 ONLY: B = 961..1024
130 REM STAR Y=1 TOP ROW, Y=16 BOTTOM ROW (960+S), Y=17 = MISSED/CATCH
140 REM MAIN LOOP
150 FOR I=1 TO 10
160 IF Y(I)>0 THEN GOSUB 600
170 NEXT I
180 SF=0
190 FOR I=1 TO 10
200 IF S(I)=0 AND SF=0 THEN GOSUB 500:SF=1
210 NEXT I
220 K$=INKEY$
230 IF K$="A" AND B>960 THEN PRINT@B," ";:B=B-1
240 IF K$="S" AND B<1025 THEN PRINT@B," ";:B=B+1
250 IF B<961 THEN B=961
260 IF B>1024 THEN B=1024
270 PRINT@B,"U";
275 REM PRINT@B," ";
280 PRINT@1,"SCORE:";SC;" ";
290 FOR T=1 TO SP:NEXT T
300 GOTO 150
500 REM SPAWN
510 S(I)=RND(64)-1
520 IF S(I)<0 THEN S(I)=0
530 Y(I)=1
540 PRINT@S(I),"*";
550 RETURN
600 REM FALL: DRAW ON ROWS 1..16; Y=17 MEANS CATCH
610 PRINT@S(I)+(Y(I)-1)*64," ";
620 Y(I)=Y(I)+1
630 IF Y(I)=17 THEN GOSUB 700
640 IF Y(I)>=1 AND Y(I)<=16 THEN PRINT@S(I)+(Y(I)-1)*64,"*";
650 RETURN
700 REM STAR LEFT BOTTOM ROW — COMPARE COLUMN TO BASKET
710 BC=B-961
720 IF ABS(S(I)-BC)<4 THEN SC=SC+10
730 Y(I)=0
740 S(I)=0
750 RETURN
