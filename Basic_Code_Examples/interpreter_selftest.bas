10 REM interpreter_selftest.bas — quick checks for ON GOSUB / ON GOTO / PEEK(14400)
20 CLS
30 PRINT "=== TRS-80 interpreter self-test ==="
40 REM --- ON GOSUB: Q=2 should run line 200 subroutine only
50 Q=2
60 ON Q GOSUB 1000,1100,1200
70 PRINT "BACK FROM ON GOSUB (EXPECT SUB 1100 ABOVE)"
80 REM --- ON GOTO: R=1 should jump to first target
90 R=1
100 ON R GOTO 200,300
110 PRINT "ON GOTO FAIL"
120 GOTO 400
200 PRINT "ON GOTO OK (TARGET 1)"
210 GOTO 400
300 PRINT "ON GOTO WRONG TARGET"
400 REM --- PEEK(14400): wait for one key
410 PRINT "PRESS ANY KEY FOR PEEK(14400) TEST..."
420 K=0
430 K=PEEK(14400)
440 IF K=0 THEN 430
450 PRINT "PEEK GOT ASCII";K
460 PRINT "=== SELF-TEST DONE ==="
470 END
1000 PRINT "SUB 1000 (WRONG IF YOU SEE)"
1010 RETURN
1100 PRINT "SUB 1100 (ON GOSUB OK)"
1110 RETURN
1200 PRINT "SUB 1200 (WRONG IF YOU SEE)"
1210 RETURN
