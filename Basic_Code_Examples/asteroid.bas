1510 REM === DRAW ALL OBJECTS ===
1520 REM ========================

1600 REM ========================
1610 REM === DRAW HUD         ===
1620 REM ========================

1700 REM ========================
1710 REM === DRAW BORDER      ===
1720 REM ========================

5000 CLS
5050 SP = 600000
5010 REM --- SHIP VARS ---
5020 SX = 64: SY = 24: REM SHIP POSITION (CENTER)
5030 SD = 1: LSX = 64: LSY = 24: LSD = 1: REM SHIP DIRECTION (1=UP) - FIX WAS 0, DDX/DDY ARRAYS ARE 1-8
5040 SVX = 0: SVY = 0: REM SHIP VELOCITY
5050 SALIVE = 1: REM SHIP ALIVE FLAG
5060 REM --- BULLET VARS (MAX 3 BULLETS) ---
5070 DIM BX(3): DIM BY(3): DIM BDX(3): DIM BDY(3): DIM BA(3)
5080 FOR I=1 TO 3: BA(I)=0: NEXT I
5090 REM --- ASTEROID VARS (MAX 8) ---
5100 DIM AX(8): DIM AY(8): DIM ADX(8): DIM ADY(8): DIM AS(8): DIM AA(8)
5110 REM AS=SIZE: 3=BIG 2=MED 1=SMALL  AA=ALIVE
5120 REM --- SCORE / LIVES ---
5130 SCORE = 0: LIVES = 3: LEVEL = 1
5140 REM --- SPAWN INITIAL ASTEROIDS ---
5150 NUMAX = 4: REM NUMBER OF ASTEROIDS THIS LEVEL
5160 GOSUB 7000: REM SPAWN ASTEROIDS
5170 REM --- DIRECTION TABLES ---
5190 DIM DDX(8): DIM DDY(8)
5200 DDX(1)=0:  DDY(1)=-1: REM UP
5210 DDX(2)=1:  DDY(2)=-1: REM UP-RIGHT
5220 DDX(3)=1:  DDY(3)=0:  REM RIGHT
5230 DDX(4)=1:  DDY(4)=1:  REM DOWN-RIGHT
5240 DDX(5)=0:  DDY(5)=1:  REM DOWN
5250 DDX(6)=-1: DDY(6)=1:  REM DOWN-LEFT
5260 DDX(7)=-1: DDY(7)=0:  REM LEFT
5270 DDX(8)=-1: DDY(8)=-1: REM UP-LEFT
5280 RETURN

6000 CLS
6010 REM NO BORDER
6020 REM --- DRAW INITIAL SHIP ---
6030 GOSUB 8000: REM DRAW SHIP
6040 REM === MAIN LOOP ===
6050 GOSUB 8500: REM READ INPUT
6060 GOSUB 8100: REM MOVE SHIP
6070 GOSUB 8200: REM MOVE BULLETS
6080 GOSUB 8300: REM MOVE ASTEROIDS
6090 GOSUB 8400: REM CHECK COLLISIONS
6100 GOSUB 8600: REM DRAW ALL OBJECTS
6110 GOSUB 8700: REM PRINT HUD
6120 IF SALIVE=0 THEN GOTO 6200
6130 REM CHECK WIN (ALL ASTEROIDS DEAD)
6140 NALIVE=0
6150 FOR I=1 TO NUMAX: IF AA(I)=1 THEN NALIVE=NALIVE+1
6160 NEXT I
6170 IF NALIVE=0 THEN GOTO 6300
6180 IF LIVES<=0 THEN GOTO 6400
6185 REM Pace main loop after full draw+HUD — stable frame stays up; raise TO to slow
6186 FOR SQ = 1 TO SP
6187 NEXT SQ
6190 GOTO 6050
6200 REM --- SHIP DESTROYED ---
6210 LIVES=LIVES-1
6220 IF LIVES<=0 THEN GOTO 6400
6230 REM RESPAWN SHIP
6240 SX=64: SY=24: SVX=0: SVY=0: SD=1: LSX=64: LSY=24: LSD=1: SALIVE=1
6250 FOR I=1 TO 3: BA(I)=0: NEXT I
6260 DELAY 50
6270 GOTO 6050
6300 REM --- NEXT LEVEL ---
6310 LEVEL=LEVEL+1
6320 NUMAX=NUMAX+2: IF NUMAX>8 THEN NUMAX=8
6330 CLS
6340 PRINT@ 321, "LEVEL "; LEVEL; " !  PRESS ANY KEY"
6350 K$=INKEY$: IF K$="" THEN GOTO 6350
6360 GOSUB 7000: REM SPAWN NEW ASTEROIDS
6370 GOTO 6000
6400 REM --- GAME OVER ---
6410 CLS
6420 PRINT@ 257, "*** GAME OVER ***"
6430 PRINT@ 321, "SCORE: "; SCORE
6440 PRINT@ 385, "PRESS R TO RESTART OR Q TO QUIT"
6450 K$=INKEY$: IF K$="" THEN GOTO 6450
6460 IF K$="R" THEN GOTO 6500
6470 IF K$="Q" THEN GOTO 6490
6480 GOTO 6450
6490 CLS: PRINT "THANKS FOR PLAYING!": END
6500 REM RESTART
6510 SCORE=0: LIVES=3: LEVEL=1: NUMAX=4
6520 SX=64: SY=24: SVX=0: SVY=0: SD=1: LSX=64: LSY=24: LSD=1: SALIVE=1
6530 FOR I=1 TO 3: BA(I)=0: NEXT I
6540 GOSUB 7000
6550 GOTO 6000

7000 FOR I=1 TO NUMAX
7010   AA(I)=1: AS(I)=3
7020   REM SPAWN FAR FROM SHIP CENTER
7030   REM PICK RANDOM EDGE POSITION
7040   EDGE = RND(4)
7050   IF EDGE=1 THEN GOTO 7080
7060   IF EDGE=2 THEN GOTO 7100
7070   IF EDGE=3 THEN GOTO 7120
7073   GOTO 7130: REM EDGE=4 RIGHT EDGE - FIX WAS FALLING THROUGH TO TOP EDGE
7080   AX(I)=RND(128): AY(I)=1: GOTO 7140
7090   GOTO 7140
7100   AX(I)=RND(128): AY(I)=47: GOTO 7140
7110   GOTO 7140
7120   AX(I)=1: AY(I)=RND(48): GOTO 7140
7130   AX(I)=127: AY(I)=RND(48)
7140   REM RANDOM VELOCITY -2 TO 2
7150   ADX(I) = RND(5)-3
7160   ADY(I) = RND(5)-3
7170   IF ADX(I)=0 AND ADY(I)=0 THEN ADX(I)=1
7180 NEXT I
7190 RETURN

8000 REM DRAW 3-PIXEL SHIP BASED ON DIRECTION SD
8005 REM NOSE=DIRECTION, TWO TAIL PIXELS=OPPOSITE WINGS
8010 SX1=INT(SX): SY1=INT(SY)
8020 REM NOSE PIXEL IN DIRECTION SD
8030 NX=SX1+DDX(SD): NY=SY1+DDY(SD)
8040 REM TAIL PIXELS OPPOSITE
8050 TX1=SX1-DDX(SD)+DDY(SD): TY1=SY1-DDY(SD)-DDX(SD)
8060 TX2=SX1-DDX(SD)-DDY(SD): TY2=SY1-DDY(SD)+DDX(SD)
8061 IF NX<1 THEN NX=1
8062 IF NX>128 THEN NX=128
8063 IF NY<1 THEN NY=1
8064 IF NY>48 THEN NY=48
8065 IF TX1<1 THEN TX1=1
8066 IF TX1>128 THEN TX1=128
8067 IF TY1<1 THEN TY1=1
8068 IF TY1>48 THEN TY1=48
8069 IF TX2<1 THEN TX2=1
8070 IF TX2>128 THEN TX2=128
8071 IF TY2<1 THEN TY2=1
8072 IF TY2>48 THEN TY2=48
8073 SET(NX,NY): SET(TX1,TY1): SET(TX2,TY2): SET(SX1,SY1)
8074 LSX=SX1: LSY=SY1: LSD=SD
8075 RETURN

8100 REM ERASE OLD SHIP
8101 SX1=LSX: SY1=LSY
8102 NX=SX1+DDX(LSD): NY=SY1+DDY(LSD)
8103 TX1=SX1-DDX(LSD)+DDY(LSD): TY1=SY1-DDY(LSD)-DDX(LSD)
8104 TX2=SX1-DDX(LSD)-DDY(LSD): TY2=SY1-DDY(LSD)+DDX(LSD)
8105 IF NX>=1 AND NX<=128 AND NY>=1 AND NY<=48 THEN RESET(NX,NY)
8106 IF TX1>=1 AND TX1<=128 AND TY1>=1 AND TY1<=48 THEN RESET(TX1,TY1)
8107 IF TX2>=1 AND TX2<=128 AND TY2>=1 AND TY2<=48 THEN RESET(TX2,TY2)
8108 IF SX1>=1 AND SX1<=128 AND SY1>=1 AND SY1<=48 THEN RESET(SX1,SY1)
8109 REM APPLY VELOCITY
8110 SX=SX+SVX: SY=SY+SVY
8111 REM WRAP AROUND SCREEN
8112 IF SX<1 THEN SX=128
8113 IF SX>128 THEN SX=1
8114 IF SY<1 THEN SY=48
8115 IF SY>48 THEN SY=1
8116 REM FRICTION
8117 SVX=SVX*0.95: SVY=SVY*0.95
8118 RETURN

8200 FOR BI=1 TO 3
8201   IF BA(BI)=0 THEN GOTO 8230
8202   REM ERASE OLD BULLET
8203   BXI=INT(BX(BI)): BYI=INT(BY(BI))
8204   IF BXI>=1 AND BXI<=128 AND BYI>=1 AND BYI<=48 THEN RESET(BXI,BYI)
8205   REM MOVE BULLET
8206   BX(BI)=BX(BI)+BDX(BI): BY(BI)=BY(BI)+BDY(BI)
8207   REM CHECK BOUNDS - KILL IF OFF SCREEN
8208   IF BX(BI)<1 OR BX(BI)>128 OR BY(BI)<1 OR BY(BI)>48 THEN BA(BI)=0
8230 NEXT BI
8240 RETURN

8300 FOR I=1 TO NUMAX
8301   IF AA(I)=0 THEN GOTO 8330
8302   REM ERASE OLD ASTEROID
8303   GOSUB 8350: REM ERASE ASTEROID I
8304   REM MOVE
8305   AX(I)=AX(I)+ADX(I): AY(I)=AY(I)+ADY(I)
8306   REM WRAP
8307   IF AX(I)<1 THEN AX(I)=128
8308   IF AX(I)>128 THEN AX(I)=1
8309   IF AY(I)<1 THEN AY(I)=48
8310   IF AY(I)>48 THEN AY(I)=1
8330 NEXT I
8340 RETURN
8350 REM ERASE ASTEROID I AT OLD POSITION
8351 AXI=INT(AX(I)): AYI=INT(AY(I)): SZI=AS(I)
8352 IF SZI=3 THEN GOTO 8360
8353 IF SZI=2 THEN GOTO 8380
8354 REM SMALL JAGGED OPEN SHAPE
8355 IF AXI>=1 AND AXI<=128 AND AYI-1>=1 AND AYI-1<=48 THEN RESET(AXI,AYI-1)
8356 IF AXI+1>=1 AND AXI+1<=128 AND AYI>=1 AND AYI<=48 THEN RESET(AXI+1,AYI)
8357 IF AXI>=1 AND AXI<=128 AND AYI+1>=1 AND AYI+1<=48 THEN RESET(AXI,AYI+1)
8358 IF AXI-1>=1 AND AXI-1<=128 AND AYI>=1 AND AYI<=48 THEN RESET(AXI-1,AYI)
8359 IF AXI-1>=1 AND AXI-1<=128 AND AYI-1>=1 AND AYI-1<=48 THEN RESET(AXI-1,AYI-1)
8360 IF SZI<>3 THEN GOTO 8370
8361 IF AXI-2>=1 AND AXI-2<=128 AND AYI-3>=1 AND AYI-3<=48 THEN RESET(AXI-2,AYI-3)
8362 IF AXI-1>=1 AND AXI-1<=128 AND AYI-3>=1 AND AYI-3<=48 THEN RESET(AXI-1,AYI-3)
8363 IF AXI+1>=1 AND AXI+1<=128 AND AYI-3>=1 AND AYI-3<=48 THEN RESET(AXI+1,AYI-3)
8364 IF AXI+2>=1 AND AXI+2<=128 AND AYI-2>=1 AND AYI-2<=48 THEN RESET(AXI+2,AYI-2)
8365 IF AXI+3>=1 AND AXI+3<=128 AND AYI-1>=1 AND AYI-1<=48 THEN RESET(AXI+3,AYI-1)
8366 IF AXI+2>=1 AND AXI+2<=128 AND AYI+1>=1 AND AYI+1<=48 THEN RESET(AXI+2,AYI+1)
8367 IF AXI+1>=1 AND AXI+1<=128 AND AYI+3>=1 AND AYI+3<=48 THEN RESET(AXI+1,AYI+3)
8368 IF AXI-1>=1 AND AXI-1<=128 AND AYI+3>=1 AND AYI+3<=48 THEN RESET(AXI-1,AYI+3)
8369 IF AXI-2>=1 AND AXI-2<=128 AND AYI+2>=1 AND AYI+2<=48 THEN RESET(AXI-2,AYI+2)
8370 IF SZI<>3 THEN GOTO 8380
8371 IF AXI-3>=1 AND AXI-3<=128 AND AYI+1>=1 AND AYI+1<=48 THEN RESET(AXI-3,AYI+1)
8372 IF AXI-3>=1 AND AXI-3<=128 AND AYI-1>=1 AND AYI-1<=48 THEN RESET(AXI-3,AYI-1)
8373 IF AXI-2>=1 AND AXI-2<=128 AND AYI-2>=1 AND AYI-2<=48 THEN RESET(AXI-2,AYI-2)
8374 IF AXI>=1 AND AXI<=128 AND AYI-2>=1 AND AYI-2<=48 THEN RESET(AXI,AYI-2)
8375 GOTO 8390
8380 REM MEDIUM JAGGED OPEN SHAPE
8381 IF AXI-1>=1 AND AXI-1<=128 AND AYI-2>=1 AND AYI-2<=48 THEN RESET(AXI-1,AYI-2)
8382 IF AXI>=1 AND AXI<=128 AND AYI-2>=1 AND AYI-2<=48 THEN RESET(AXI,AYI-2)
8383 IF AXI+1>=1 AND AXI+1<=128 AND AYI-1>=1 AND AYI-1<=48 THEN RESET(AXI+1,AYI-1)
8384 IF AXI+2>=1 AND AXI+2<=128 AND AYI>=1 AND AYI<=48 THEN RESET(AXI+2,AYI)
8385 IF AXI+1>=1 AND AXI+1<=128 AND AYI+1>=1 AND AYI+1<=48 THEN RESET(AXI+1,AYI+1)
8386 IF AXI>=1 AND AXI<=128 AND AYI+2>=1 AND AYI+2<=48 THEN RESET(AXI,AYI+2)
8387 IF AXI-1>=1 AND AXI-1<=128 AND AYI+2>=1 AND AYI+2<=48 THEN RESET(AXI-1,AYI+2)
8388 IF AXI-2>=1 AND AXI-2<=128 AND AYI+1>=1 AND AYI+1<=48 THEN RESET(AXI-2,AYI+1)
8389 IF AXI-2>=1 AND AXI-2<=128 AND AYI-1>=1 AND AYI-1<=48 THEN RESET(AXI-2,AYI-1)
8389.1 IF AXI-1>=1 AND AXI-1<=128 AND AYI>=1 AND AYI<=48 THEN RESET(AXI-1,AYI)
8390 RETURN

8400 REM CHECK BULLETS VS ASTEROIDS
8401 FOR BI=1 TO 3
8402   IF BA(BI)=0 THEN GOTO 8440
8403   FOR I=1 TO NUMAX
8404     IF AA(I)=0 THEN GOTO 8435
8405     REM CHECK DISTANCE
8406     DX=ABS(BX(BI)-AX(I)): DY=ABS(BY(BI)-AY(I))
8407     HIT=AS(I)*2: REM HIT RADIUS
8408     IF DX<=HIT AND DY<=HIT THEN GOTO 8410
8409     GOTO 8435
8410     REM HIT! DESTROY ASTEROID
8411     BA(BI)=0: REM KILL BULLET
8412     GOSUB 8350: REM ERASE ASTEROID
8413     IF AS(I)=1 THEN GOTO 8425: REM SMALL - JUST KILL
8414     REM SPLIT ASTEROID
8415     NEWSZ=AS(I)-1
8416     REM FIND FREE SLOT FOR CHILD
8417     AA(I)=0: REM KILL PARENT
8418     FOR J=1 TO NUMAX
8419       IF AA(J)=0 THEN GOTO 8422
8420     NEXT J
8421     GOTO 8425
8422     AA(J)=1: AS(J)=NEWSZ
8423     AX(J)=AX(I)+RND(5)-3: AY(J)=AY(I)+RND(5)-3
8424     ADX(J)=RND(5)-3: ADY(J)=RND(5)-3
8425     AA(I)=0
8426     SCORE=SCORE+(4-AS(I))*10+10
8427     GOTO 8440
8435   NEXT I
8440 NEXT BI
8445 REM CHECK SHIP VS ASTEROIDS
8446 IF SALIVE=0 THEN RETURN
8447 FOR I=1 TO NUMAX
8448   IF AA(I)=0 THEN GOTO 8460
8449   DX=ABS(SX-AX(I)): DY=ABS(SY-AY(I))
8450   HIT=AS(I)+1
8451   IF DX<=HIT AND DY<=HIT THEN SALIVE=0: RETURN
8460 NEXT I
8470 RETURN

8500 K=PEEK(14400)
8510 IF K=90 THEN SD=SD-1: IF SD<1 THEN SD=8
8520 IF K=88 THEN SD=SD+1: IF SD>8 THEN SD=1
8530 IF K=47 THEN GOSUB 8550: REM THRUST
8540 IF K=32 THEN GOSUB 8580: REM FIRE
8545 IF K=81 THEN CLS: PRINT "QUIT!": END
8546 RETURN
8550 REM THRUST
8555 SVX=SVX+DDX(SD)
8560 SVY=SVY+DDY(SD)
8565 REM CAP SPEED AT 3
8566 IF SVX>3 THEN SVX=3
8567 IF SVX<-3 THEN SVX=-3
8568 IF SVY>3 THEN SVY=3
8569 IF SVY<-3 THEN SVY=-3
8570 RETURN
8580 REM FIRE BULLET - FIND FREE SLOT
8585 FOR BI=1 TO 3
8586   IF BA(BI)=0 THEN GOTO 8590
8587 NEXT BI
8588 RETURN
8590 BA(BI)=1
8591 BX(BI)=SX: BY(BI)=SY
8592 BDX(BI)=DDX(SD)*4: BDY(BI)=DDY(SD)*4
8593 RETURN

8600 REM DRAW ASTEROIDS
8601 FOR I=1 TO NUMAX
8602   IF AA(I)=0 THEN GOTO 8640
8603   AXI=INT(AX(I)): AYI=INT(AY(I)): SZI=AS(I)
8604   IF SZI=3 THEN GOTO 8610
8605   IF SZI=2 THEN GOTO 8625
8606   REM SMALL JAGGED OPEN SHAPE
8607   IF AXI>=1 AND AXI<=128 AND AYI-1>=1 AND AYI-1<=48 THEN SET(AXI,AYI-1)
8608   IF AXI+1>=1 AND AXI+1<=128 AND AYI>=1 AND AYI<=48 THEN SET(AXI+1,AYI)
8609   IF AXI>=1 AND AXI<=128 AND AYI+1>=1 AND AYI+1<=48 THEN SET(AXI,AYI+1)
8610   IF SZI<>3 THEN GOTO 8616
8611   IF AXI-2>=1 AND AXI-2<=128 AND AYI-3>=1 AND AYI-3<=48 THEN SET(AXI-2,AYI-3)
8612   IF AXI-1>=1 AND AXI-1<=128 AND AYI-3>=1 AND AYI-3<=48 THEN SET(AXI-1,AYI-3)
8613   IF AXI+1>=1 AND AXI+1<=128 AND AYI-3>=1 AND AYI-3<=48 THEN SET(AXI+1,AYI-3)
8614   IF AXI+2>=1 AND AXI+2<=128 AND AYI-2>=1 AND AYI-2<=48 THEN SET(AXI+2,AYI-2)
8615   IF AXI+3>=1 AND AXI+3<=128 AND AYI-1>=1 AND AYI-1<=48 THEN SET(AXI+3,AYI-1)
8616   IF SZI<>3 THEN GOTO 8622
8617   IF AXI+2>=1 AND AXI+2<=128 AND AYI+1>=1 AND AYI+1<=48 THEN SET(AXI+2,AYI+1)
8618   IF AXI+1>=1 AND AXI+1<=128 AND AYI+3>=1 AND AYI+3<=48 THEN SET(AXI+1,AYI+3)
8619   IF AXI-1>=1 AND AXI-1<=128 AND AYI+3>=1 AND AYI+3<=48 THEN SET(AXI-1,AYI+3)
8620   IF AXI-2>=1 AND AXI-2<=128 AND AYI+2>=1 AND AYI+2<=48 THEN SET(AXI-2,AYI+2)
8621   IF AXI-3>=1 AND AXI-3<=128 AND AYI+1>=1 AND AYI+1<=48 THEN SET(AXI-3,AYI+1)
8622   IF SZI<>3 THEN GOTO 8640
8623   IF AXI-3>=1 AND AXI-3<=128 AND AYI-1>=1 AND AYI-1<=48 THEN SET(AXI-3,AYI-1)
8624   IF AXI-2>=1 AND AXI-2<=128 AND AYI-2>=1 AND AYI-2<=48 THEN SET(AXI-2,AYI-2)
8625   IF SZI<>2 THEN GOTO 8636
8626   IF AXI-1>=1 AND AXI-1<=128 AND AYI-2>=1 AND AYI-2<=48 THEN SET(AXI-1,AYI-2)
8627   IF AXI>=1 AND AXI<=128 AND AYI-2>=1 AND AYI-2<=48 THEN SET(AXI,AYI-2)
8628   IF AXI+1>=1 AND AXI+1<=128 AND AYI-1>=1 AND AYI-1<=48 THEN SET(AXI+1,AYI-1)
8629   IF AXI+2>=1 AND AXI+2<=128 AND AYI>=1 AND AYI<=48 THEN SET(AXI+2,AYI)
8630   IF AXI+1>=1 AND AXI+1<=128 AND AYI+1>=1 AND AYI+1<=48 THEN SET(AXI+1,AYI+1)
8631   IF AXI>=1 AND AXI<=128 AND AYI+2>=1 AND AYI+2<=48 THEN SET(AXI,AYI+2)
8632   IF AXI-1>=1 AND AXI-1<=128 AND AYI+2>=1 AND AYI+2<=48 THEN SET(AXI-1,AYI+2)
8633   IF AXI-2>=1 AND AXI-2<=128 AND AYI+1>=1 AND AYI+1<=48 THEN SET(AXI-2,AYI+1)
8634   IF AXI-2>=1 AND AXI-2<=128 AND AYI-1>=1 AND AYI-1<=48 THEN SET(AXI-2,AYI-1)
8635   IF AXI-1>=1 AND AXI-1<=128 AND AYI>=1 AND AYI<=48 THEN SET(AXI-1,AYI)
8636   IF SZI<>1 THEN GOTO 8640
8637   IF AXI-1>=1 AND AXI-1<=128 AND AYI>=1 AND AYI<=48 THEN SET(AXI-1,AYI)
8638   IF AXI-1>=1 AND AXI-1<=128 AND AYI-1>=1 AND AYI-1<=48 THEN SET(AXI-1,AYI-1)
8640 NEXT I
8650 REM DRAW BULLETS
8651 FOR BI=1 TO 3
8652   IF BA(BI)=0 THEN GOTO 8660
8653   BXI=INT(BX(BI)): BYI=INT(BY(BI))
8654   IF BXI>=1 AND BXI<=128 AND BYI>=1 AND BYI<=48 THEN SET(BXI,BYI)
8660 NEXT BI
8665 REM DRAW SHIP
8666 IF SALIVE=1 THEN GOSUB 8000
8670 RETURN

1600 REM ========================
1610 REM === DRAW HUD         ===
1620 REM ========================
8700 PRINT@ 961, "SCORE:";SCORE;"  LIVES:";LIVES;"  LVL:";LEVEL;"  ";
8710 RETURN

9000 REM DRAW TOP AND BOTTOM BORDERS
9010 FOR X=1 TO 128: SET(X,1): SET(X,47): NEXT X
9020 REM DRAW LEFT AND RIGHT BORDERS
9030 FOR Y=1 TO 47: SET(1,Y): SET(128,Y): NEXT Y
9040 RETURN
