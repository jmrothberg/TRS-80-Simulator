1 REM === PRINT / PRINT@ TEST SUITE ===
2 REM LOAD THIS AND RUN. EACH TEST PAUSES FOR ENTER.
3 REM COMPARE PYTHON VS JAVASCRIPT OUTPUT.
4 REM ROW NUMBERING: ROW1=TOP (PRINT@1), ROW2=PRINT@65, ETC.
5 GOSUB 100:REM TEST 1 — OVERWRITE
6 GOSUB 200:REM TEST 2 — CURSOR AFTER PRINT@ NO SEMI
7 GOSUB 300:REM TEST 3 — CURSOR AFTER PRINT@ WITH SEMI
8 GOSUB 400:REM TEST 4 — COL OVERFLOW WRAP
9 GOSUB 500:REM TEST 5 — FULL ROW WRITE
10 GOSUB 600:REM TEST 6 — RAPID PRINT@ SAME CELL
11 GOSUB 700:REM TEST 7 — PRINT@ THEN PLAIN PRINT
12 CLS:PRINT "ALL TESTS DONE":STOP
100 REM === TEST 1: OVERWRITE ===
110 CLS:PRINT@ 1,"TEST 1: OVERWRITE"
120 PRINT@ 65,"AAAAAAAAAA"
130 PRINT@ 65,"BBBBB"
140 PRINT@ 193,"EXPECT: ROW2=BBBBBAAAAA"
150 PRINT@ 257,"(5 B'S REPLACE FIRST 5 A'S, REST STAYS)"
160 PRINT@ 897,"PRESS ENTER";:INPUT A$:RETURN
200 REM === TEST 2: CURSOR AFTER PRINT@ (NO SEMICOLON) ===
210 CLS:PRINT@ 1,"TEST 2: CURSOR AFTER PRINT@ (NO ;)"
220 PRINT@ 65,"HELLO"
230 PRINT "WORLD"
240 PRINT@ 257,"EXPECT: ROW2=HELLO  ROW3=WORLD"
250 PRINT@ 321,"(NO ; SO NEWLINE AFTER HELLO, WORLD ON NEXT ROW)"
260 PRINT@ 897,"PRESS ENTER";:INPUT A$:RETURN
300 REM === TEST 3: CURSOR AFTER PRINT@ (WITH SEMICOLON) ===
310 CLS:PRINT@ 1,"TEST 3: CURSOR AFTER PRINT@ (WITH ;)"
320 PRINT@ 65,"HELLO";
330 PRINT "WORLD"
340 PRINT@ 193,"EXPECT: ROW2=HELLOWORLD (SAME ROW)"
350 PRINT@ 257,"(; KEEPS CURSOR AFTER HELLO, WORLD FOLLOWS)"
360 PRINT@ 897,"PRESS ENTER";:INPUT A$:RETURN
400 REM === TEST 4: COLUMN OVERFLOW WRAP ===
410 CLS:PRINT@ 1,"TEST 4: COLUMN OVERFLOW WRAP"
420 PRINT@ 120,"ABCDEFGHIJ"
425 REM POS 120-1=119. ROW=119/64=1 COL=119%64=55. 10 CHARS AT COLS 55-64. COL64 WRAPS.
430 PRINT@ 257,"EXPECT: ROW2 ENDS ...ABCDEFGHI"
440 PRINT@ 321,"EXPECT: ROW3 STARTS WITH J"
450 PRINT@ 385,"IF J IS MISSING = BUG (COL OVERFLOW DROP)"
460 PRINT@ 897,"PRESS ENTER";:INPUT A$:RETURN
500 REM === TEST 5: FULL ROW THEN NEWLINE ===
510 CLS:PRINT@ 1,"TEST 5: 64-CHAR ROW + NEWLINE"
520 A$=STRING$(64,"*")
530 PRINT@ 65,A$
540 PRINT "X MARKS THE SPOT"
550 PRINT@ 257,"EXPECT: ROW2=64 STARS"
560 PRINT@ 321,"EXPECT: ROW3=X MARKS THE SPOT"
570 PRINT@ 385,"(NOT ROW4 — ONLY ONE ROW ADVANCE)"
580 PRINT@ 897,"PRESS ENTER";:INPUT A$:RETURN
600 REM === TEST 6: RAPID OVERWRITE SAME CELL ===
610 CLS:PRINT@ 1,"TEST 6: RAPID OVERWRITE SAME CELL"
620 FOR I=1 TO 9:PRINT@ 65,MID$(STR$(I),2):NEXT I
630 PRINT@ 193,"EXPECT: ROW2 COL1 = 9 (ONLY 9 VISIBLE)"
640 PRINT@ 257,"IF YOU SEE OVERLAPPING DIGITS = BUG"
650 PRINT@ 897,"PRESS ENTER";:INPUT A$:RETURN
700 REM === TEST 7: PRINT@ THEN PLAIN PRINT POSITION ===
710 CLS:PRINT@ 1,"TEST 7: PRINT@ WITH ; THEN PRINT"
720 PRINT@ 65,"A=";
730 PRINT 42
740 PRINT@ 257,"EXPECT: ROW2 = A= 42  (SAME ROW)"
750 PRINT@ 897,"PRESS ENTER";:INPUT A$:RETURN
