10 REM *** HANGMAN FOR TRS-80 MODEL I LEVEL II BASIC ***
20 REM *** INITIALIZE ***
30 DIM W$(29)
40 DIM G$(25)
50 DIM U$(25)
60 REM *** LOAD WORD LIST ***
70 RESTORE
80 FOR I=0 TO 29
90 READ W$(I)
100 NEXT I
110 REM *** MAIN GAME LOOP ***
120 CLS
130 PRINT "**************************"
140 PRINT "*   T R S - 8 0          *"
150 PRINT "*   H A N G M A N        *"
160 PRINT "**************************"
170 PRINT
180 PRINT "PRESS ANY KEY TO PLAY..."
190 K$=INKEY$
200 IF K$="" THEN GOTO 190
210 REM *** PICK A RANDOM WORD ***
220 WI=INT(RND(0)*30)
230 W$=W$(WI)
230 WL=LEN(W$)
240 REM *** RESET GUESSES ***
250 WRONG=0
260 FOR I=0 TO 25
270 G$(I)=""
280 NEXT I
290 REM *** BUILD BLANK DISPLAY ***
300 FOR I=1 TO WL
310 U$(I)="-"
320 NEXT I
330 REM *** GAME LOOP ***
340 CLS
350 GOSUB 800
360 GOSUB 900
370 REM *** CHECK WIN ***
380 WIN=1
390 FOR I=1 TO WL
400 IF U$(I)="-" THEN WIN=0
410 NEXT I
420 IF WIN=1 THEN GOTO 700
430 IF WRONG>=6 THEN GOTO 750
440 REM *** GET GUESS ***
450 PRINT
460 PRINT "GUESS A LETTER: ";
470 K$=INKEY$
480 IF K$="" THEN GOTO 470
490 REM *** VALIDATE LETTER ***
500 IF ASC(K$)<65 OR ASC(K$)>90 THEN GOTO 470
510 REM *** CHECK IF ALREADY GUESSED ***
520 FOR I=0 TO 25
530 IF G$(I)=K$ THEN GOTO 470
540 NEXT I
550 REM *** STORE GUESS ***
560 G$(ASC(K$)-65)=K$
570 REM *** CHECK LETTER IN WORD ***
580 FOUND=0
590 FOR I=1 TO WL
600 IF MID$(W$,I,1)=K$ THEN U$(I)=K$: FOUND=1
610 NEXT I
620 IF FOUND=0 THEN WRONG=WRONG+1
630 GOTO 340
700 REM *** WIN ***
710 CLS
720 GOSUB 800
730 PRINT
740 PRINT "*** YOU WIN! THE WORD WAS: "; W$; " ***"
745 PRINT
746 PRINT "PLAY AGAIN? (Y/N)"
747 K$=INKEY$
748 IF K$="" THEN GOTO 747
749 IF K$="Y" THEN GOTO 210
750 REM *** LOSE ***
755 IF WIN=1 THEN GOTO 780
760 CLS
761 GOSUB 800
762 PRINT
763 PRINT "*** YOU LOSE! THE WORD WAS: "; W$; " ***"
764 PRINT
765 PRINT "PLAY AGAIN? (Y/N)"
766 K$=INKEY$
767 IF K$="" THEN GOTO 766
768 IF K$="Y" THEN GOTO 210
770 CLS
771 PRINT "THANKS FOR PLAYING HANGMAN!"
772 END
780 PRINT "THANKS FOR PLAYING HANGMAN!"
790 END
800 REM *** DRAW GALLOWS AND MAN ***
810 PRINT "+-------+"
820 PRINT "|       |"
830 IF WRONG>=1 THEN PRINT "|       O" ELSE PRINT "|        "
840 IF WRONG>=3 THEN PRINT "|      /|\\" ELSE IF WRONG>=2 THEN PRINT "|      /|" ELSE PRINT "|        "
850 IF WRONG>=5 THEN PRINT "|      / \\" ELSE IF WRONG>=4 THEN PRINT "|      /  " ELSE PRINT "|        "
860 PRINT "|"
870 PRINT "+---------"
880 PRINT "WRONG GUESSES: "; WRONG; " OF 6"
890 RETURN
900 REM *** DRAW WORD AND GUESSES ***
910 PRINT
920 PRINT "WORD:  ";
930 FOR I=1 TO WL
940 PRINT U$(I); " ";
950 NEXT I
960 PRINT
970 PRINT
980 PRINT "LETTERS GUESSED: ";
990 FOR I=0 TO 25
1000 IF G$(I)<>"" THEN PRINT G$(I); " ";
1010 NEXT I
1020 PRINT
1030 RETURN
2000 REM *** WORD LIST ***
2010 DATA "APPLE","BRAVE","CLOCK","DANCE","EAGLE"
2020 DATA "FLAME","GRAPE","HOUSE","IVORY","JOKER"
2030 DATA "KNIFE","LEMON","MAGIC","NIGHT","OCEAN"
2040 DATA "PIANO","QUEEN","RIVER","STONE","TIGER"
2050 DATA "ULTRA","VIVID","WITCH","XENON","YACHT"
2060 DATA "ZEBRA","FROST","GLOBE","HONEY","INBOX"
