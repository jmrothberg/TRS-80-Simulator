10 REM JMR'S BASIC SPACE INVADERS VI
20 REM SMOOTH NO-CLS VERSION FOR TRS-80 MODEL 1 SIMULATOR
30 REM A=LEFT S=RIGHT SPACE=FIRE
40 GOTO 100

100 REM INITIALIZE VARIABLES
110 LET S = 64
115 LET GS = 64
120 DIM B(5)
125 DIM EB(3)
130 DIM E(15)
135 DIM BK(60)
140 LET D = 1
150 LET SC = 0
160 LET LV = 3
170 LET SP = 10
180 LET F = 2
190 LET L = 2
195 LET M = 0
196 LET A = 0
200 GOSUB 7000
210 FOR I = 1 TO 60
220 LET BK(I) = 1
230 NEXT I
240 FOR I = 1 TO 5
250 LET B(I) = 0
260 NEXT I
270 FOR I = 1 TO 3
280 LET EB(I) = 0
290 NEXT I
295 CLS
296 GOSUB 1000
297 GOTO 300

300 REM MAIN GAME LOOP
310 GOSUB 2000
320 GOSUB 1900
330 GOSUB 3000
340 GOSUB 4000
350 GOSUB 1000
360 FOR W = 1 TO SP
370 NEXT W
380 GOTO 300

1000 REM DRAW FRAME WITHOUT CLS
1010 PRINT@ 1, "SCORE:"; SC; "  LIVES:"; LV; "   ";
1030 FOR I = 1 TO 15
1040 IF E(I) > 0 THEN GOSUB 1500
1050 NEXT I
1060 GOSUB 1600
1070 FOR I = 1 TO 5
1080 IF B(I) > 0 THEN GOSUB 1700
1090 NEXT I
1095 FOR I = 1 TO 3
1096 IF EB(I) > 0 THEN GOSUB 1800
1097 NEXT I
1098 GOSUB 9700
1100 RETURN

1500 REM DRAW IMPROVED INVADER SPRITE
1510 LET X = E(I) MOD 128
1520 LET Y = INT(E(I) / 128)
1530 IF A = 0 THEN GOTO 1560
1540 REM FRAME B
1541 SET(X+2,Y): SET(X+5,Y)
1542 SET(X+1,Y+1): SET(X+2,Y+1): SET(X+5,Y+1): SET(X+6,Y+1)
1543 FOR P = 0 TO 7
1544 SET(X+P,Y+2)
1545 NEXT P
1546 SET(X+1,Y+3): SET(X+3,Y+3): SET(X+4,Y+3): SET(X+6,Y+3)
1547 SET(X+2,Y+4): SET(X+5,Y+4)
1548 SET(X+1,Y+5): SET(X+3,Y+5): SET(X+4,Y+5): SET(X+6,Y+5)
1549 RETURN
1560 REM FRAME A
1561 SET(X+2,Y): SET(X+5,Y)
1562 SET(X+1,Y+1): SET(X+2,Y+1): SET(X+5,Y+1): SET(X+6,Y+1)
1563 FOR P = 0 TO 7
1564 SET(X+P,Y+2)
1565 NEXT P
1566 SET(X,Y+3): SET(X+2,Y+3): SET(X+3,Y+3): SET(X+4,Y+3): SET(X+5,Y+3): SET(X+7,Y+3)
1567 SET(X,Y+4): SET(X+2,Y+4): SET(X+5,Y+4): SET(X+7,Y+4)
1568 SET(X+1,Y+5): SET(X+6,Y+5)
1569 RETURN

1600 REM DRAW GUN
1610 SET(S,47)
1620 SET(S-1,47)
1630 SET(S+1,47)
1640 SET(S,46)
1645 LET GS = S
1650 RETURN

1660 REM ERASE GUN
1670 RESET(GS,47)
1680 RESET(GS-1,47)
1690 RESET(GS+1,47)
1695 RESET(GS,46)
1696 RETURN

1700 REM DRAW PLAYER BULLET
1710 LET BX = B(I) MOD 128
1720 LET BY = INT(B(I) / 128)
1730 SET(BX,BY)
1740 RETURN

1760 REM ERASE PLAYER BULLET
1770 LET BX = B(I) MOD 128
1780 LET BY = INT(B(I) / 128)
1790 RESET(BX,BY)
1795 RETURN

1800 REM DRAW ENEMY BULLET
1810 LET BX = EB(I) MOD 128
1820 LET BY = INT(EB(I) / 128)
1830 SET(BX,BY)
1840 RETURN

1860 REM ERASE ENEMY BULLET
1870 LET BX = EB(I) MOD 128
1880 LET BY = INT(EB(I) / 128)
1890 RESET(BX,BY)
1895 RETURN

1900 REM ERASE MOVING OBJECTS ONLY
1910 FOR I = 1 TO 15
1920 IF E(I) > 0 THEN GOSUB 1960
1930 NEXT I
1940 GOSUB 1660
1945 FOR I = 1 TO 5
1946 IF B(I) > 0 THEN GOSUB 1760
1947 NEXT I
1948 FOR I = 1 TO 3
1949 IF EB(I) > 0 THEN GOSUB 1860
1950 NEXT I
1955 RETURN

1960 REM ERASE ENEMY USING BOUNDING BOX
1970 LET X = E(I) MOD 128
1980 LET Y = INT(E(I) / 128)
1990 FOR DY = 0 TO 5
1992 FOR DX = 0 TO 7
1994 IF X+DX <= 128 AND Y+DY <= 48 THEN RESET(X+DX,Y+DY)
1996 NEXT DX
1998 NEXT DY
1999 RETURN

2000 REM CHECK INPUT
2010 LET K = PEEK(14400)
2020 IF K = 65 THEN GOSUB 2100
2030 IF K = 83 THEN GOSUB 2200
2040 IF K = 32 THEN GOSUB 2300
2050 RETURN

2100 REM MOVE LEFT
2110 IF S > 2 THEN LET S = S - F
2120 RETURN

2200 REM MOVE RIGHT
2210 IF S < 126 THEN LET S = S + F
2220 RETURN

2300 REM FIRE BULLET
2310 FOR I = 1 TO 5
2320 IF B(I) = 0 THEN LET B(I) = S + 45 * 128
2325 IF B(I) = S + 45 * 128 THEN RETURN
2330 NEXT I
2340 RETURN

3000 REM UPDATE GAME STATE
3010 FOR I = 1 TO 5
3020 IF B(I) > 0 THEN LET B(I) = B(I) - 128 * L
3030 IF B(I) < 1 THEN LET B(I) = 0
3040 NEXT I
3050 FOR I = 1 TO 3
3060 IF EB(I) > 0 THEN LET EB(I) = EB(I) + 128 * L
3070 IF EB(I) > 6144 THEN LET EB(I) = 0
3080 NEXT I
3090 LET M = M + 1
3100 IF M < 3 THEN RETURN
3110 LET M = 0
3120 LET A = 1 - A
3130 FOR I = 1 TO 15
3140 IF E(I) > 0 THEN LET E(I) = E(I) + D
3150 IF E(I) > 0 THEN GOSUB 3200
3160 NEXT I
3170 GOSUB 3300
3180 RETURN

3200 REM CHECK ENEMY BOUNDARIES - KEEP THIS SIMPLE, THIS PATTERN WORKS IN V
3210 LET X = E(I) MOD 128
3220 IF X = 0 OR X = 127 THEN GOSUB 3250
3230 RETURN

3250 REM REVERSE DIRECTION AND MOVE DOWN
3260 LET D = -D
3270 FOR J = 1 TO 15
3280 IF E(J) > 0 THEN LET E(J) = E(J) + 256
3290 NEXT J
3295 RETURN

3300 REM ENEMY SHOOTS
3310 IF RND <= 0.96 THEN RETURN
3320 LET R = RND(15)
3330 IF E(R) = 0 THEN RETURN
3340 FOR I = 1 TO 3
3350 IF EB(I) = 0 THEN LET EB(I) = E(R) + 771
3355 IF EB(I) = E(R) + 771 THEN RETURN
3360 NEXT I
3370 RETURN

4000 REM CHECK COLLISIONS
4010 FOR I = 1 TO 15
4020 FOR J = 1 TO 5
4030 IF B(J) > 0 AND E(I) > 0 THEN GOSUB 4100
4040 NEXT J
4050 IF E(I) > 5440 THEN GOSUB 6000
4060 NEXT I
4070 GOSUB 4200
4080 GOSUB 4500
4090 RETURN

4100 REM CHECK BULLET HIT ENEMY
4110 LET BX = B(J) MOD 128
4120 LET BY = INT(B(J) / 128)
4130 LET EX = E(I) MOD 128
4140 LET EY = INT(E(I) / 128)
4150 IF BX >= EX AND BX < EX+8 AND BY >= EY AND BY < EY+6 THEN GOSUB 5000
4160 RETURN

4200 REM CHECK BUNKER HITS
4210 FOR I = 1 TO 60
4220 IF BK(I) = 1 THEN GOSUB 4300
4230 NEXT I
4240 RETURN

4300 REM CHECK BULLET HIT BUNKER
4310 LET BN = INT((I-1)/15) + 1
4320 LET BP = (I-1) MOD 15 + 1
4330 IF BP <= 5 THEN LET BX = BP + 28 + (BN-1) * 24
4335 IF BP > 5 AND BP <= 10 THEN LET BX = BP + 23 + (BN-1) * 24
4336 IF BP > 10 THEN LET BX = BP + 18 + (BN-1) * 24
4340 LET BY = 44 - INT((BP-1)/5)
4350 FOR K = 1 TO 5
4360 IF B(K) > 0 THEN GOSUB 4400
4370 NEXT K
4375 FOR K = 1 TO 3
4380 IF EB(K) > 0 THEN GOSUB 4450
4385 NEXT K
4390 RETURN

4400 REM PLAYER BULLET HIT BUNKER
4410 LET BBX = B(K) MOD 128
4420 LET BBY = INT(B(K) / 128)
4430 IF BBX = BX AND BBY = BY THEN LET BK(I) = 0
4435 IF BBX = BX AND BBY = BY THEN LET B(K) = 0
4440 RETURN

4450 REM ENEMY BULLET HIT BUNKER
4460 LET BBX = EB(K) MOD 128
4470 LET BBY = INT(EB(K) / 128)
4480 IF BBX = BX AND BBY = BY THEN LET BK(I) = 0
4485 IF BBX = BX AND BBY = BY THEN LET EB(K) = 0
4490 RETURN

4500 REM CHECK PLAYER HIT
4510 FOR I = 1 TO 3
4520 IF EB(I) > 0 THEN GOSUB 4550
4530 NEXT I
4540 RETURN

4550 REM CHECK SINGLE ENEMY BULLET
4560 LET BX = EB(I) MOD 128
4570 LET BY = INT(EB(I) / 128)
4580 IF BY >= 46 AND ABS(BX - S) <= 1 THEN GOSUB 6000
4590 RETURN

5000 REM HIT ENEMY
5010 LET SC = SC + 10
5015 GOSUB 1960
5020 LET E(I) = 0
5030 LET B(J) = 0
5040 GOSUB 5200
5050 RETURN

5200 REM CHECK IF ALL ENEMIES DESTROYED
5210 LET C = 0
5220 FOR N = 1 TO 15
5230 IF E(N) > 0 THEN LET C = C + 1
5240 NEXT N
5250 IF C = 0 THEN GOSUB 7100
5260 RETURN

6000 REM PLAYER HIT
6010 LET LV = LV - 1
6020 IF LV = 0 THEN GOTO 8000
6030 CLS
6040 FOR Q = 1 TO 5
6050 LET B(Q) = 0
6060 NEXT Q
6070 FOR T = 1 TO 3
6080 LET EB(T) = 0
6090 NEXT T
6100 LET S = 64
6105 LET GS = 64
6110 GOSUB 7000
6120 GOSUB 1000
6130 RETURN

7000 REM RESPAWN ENEMIES
7010 FOR N = 1 TO 15
7020 LET R = INT((N-1)/5)
7030 LET C = N - 1 - (R * 5)
7040 LET E(N) = (6 + R * 8) * 128 + (10 + C * 20)
7050 NEXT N
7060 RETURN

7100 REM NEXT WAVE
7110 IF SP > 4 THEN LET SP = SP - 1
7120 FOR Q = 1 TO 5
7130 LET B(Q) = 0
7140 NEXT Q
7150 FOR T = 1 TO 3
7160 LET EB(T) = 0
7170 NEXT T
7180 GOSUB 7000
7190 RETURN

8000 REM GAME OVER
8010 CLS
8020 PRINT@ 321, "GAME OVER"
8030 PRINT@ 385, "SCORE:"; SC
8040 PRINT@ 449, "PRESS ANY KEY"
8050 IF PEEK(14400) = 0 THEN GOTO 8050
8060 GOTO 100

9700 REM DRAW BUNKERS
9710 FOR I = 1 TO 4
9720 FOR J = 1 TO 5
9730 IF BK((I-1)*15+J) = 1 THEN SET(J+28+(I-1)*24,45)
9740 NEXT J
9750 FOR J = 6 TO 10
9760 IF BK((I-1)*15+J) = 1 THEN SET(J+23+(I-1)*24,44)
9770 NEXT J
9780 FOR J = 11 TO 15
9790 IF BK((I-1)*15+J) = 1 THEN SET(J+18+(I-1)*24,43)
9800 NEXT J
9810 NEXT I
9820 RETURN
