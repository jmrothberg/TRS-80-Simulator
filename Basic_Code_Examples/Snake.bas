10 REM SNAKE GAME FOR TRS-80
20 REM BY CLAUDE, MARCH 2026
30 CLS
40 PRINT "       *** SNAKE ***"
50 PRINT
60 PRINT "  W - UP    S - DOWN"
70 PRINT "  A - LEFT  D - RIGHT"
80 PRINT
90 PRINT "  EAT FOOD TO GROW AND SCORE"
92 PRINT "  AVOID WALLS AND YOURSELF"
94 PRINT
96 PRINT "  PRESS ANY KEY TO START"
98 IF INKEY$ = "" THEN GOTO 98
100 REM INITIALIZE
110 CLS
120 DIM X(200)
130 DIM Y(200)
140 LET H = 5
150 LET T = 1
160 LET DX = 1
170 LET DY = 0
180 LET SC = 0
190 LET SP = 10
200 REM PLACE STARTING SNAKE (5 LONG, CENTER)
210 FOR I = 1 TO 5
220 LET X(I) = 10 + I
230 LET Y(I) = 24
240 SET(X(I), Y(I))
250 NEXT I
300 REM DRAW BORDER
310 FOR I = 1 TO 128
320 SET(I, 4)
330 SET(I, 47)
340 NEXT I
350 FOR I = 4 TO 47
360 SET(1, I)
370 SET(128, I)
380 NEXT I
390 GOSUB 800
395 PRINT@1, "SNAKE  SCORE:"; SC;
400 REM MAIN GAME LOOP
410 LET K = PEEK(14400)
420 IF K = 87 AND DY = 0 THEN LET DX = 0: LET DY = -1
430 IF K = 83 AND DY = 0 THEN LET DX = 0: LET DY = 1
440 IF K = 65 AND DX = 0 THEN LET DX = -1: LET DY = 0
450 IF K = 68 AND DX = 0 THEN LET DX = 1: LET DY = 0
460 REM CALC NEW HEAD POSITION
470 LET NX = X(H) + DX
480 LET NY = Y(H) + DY
500 REM WALL CHECK
510 IF NX < 2 OR NX > 127 THEN GOTO 900
520 IF NY < 5 OR NY > 46 THEN GOTO 900
530 REM BODY CHECK (ALLOW FOOD AND TAIL POS)
540 IF POINT(NX, NY) = 0 THEN GOTO 600
550 IF NX = FX AND NY = FY THEN GOTO 600
560 IF NX = X(T) AND NY = Y(T) THEN GOTO 600
570 GOTO 900
600 REM ADVANCE SNAKE HEAD
610 LET H = H + 1
620 IF H > 200 THEN LET H = 1
630 LET X(H) = NX
640 LET Y(H) = NY
650 SET(NX, NY)
660 REM ATE FOOD?
670 IF NX <> FX OR NY <> FY THEN GOTO 730
680 LET SC = SC + 10
690 IF SP > 50 THEN LET SP = SP - 20
700 GOSUB 800
710 GOTO 760
730 REM ERASE TAIL (SNAKE DID NOT GROW)
740 RESET(X(T), Y(T))
750 LET T = T + 1
755 IF T > 200 THEN LET T = 1
760 REM DISPLAY SCORE AND DELAY
770 PRINT@1, "SNAKE  SCORE:"; SC;
780 FOR W = 1 TO SP
790 NEXT W
795 GOTO 400
800 REM PLACE FOOD SUBROUTINE
810 LET FX = RND(126) + 1
820 LET FY = RND(42) + 4
830 IF POINT(FX, FY) = 1 THEN GOTO 810
840 SET(FX, FY)
850 RETURN
900 REM GAME OVER
910 PRINT@65, "  GAME OVER!  ";
920 PRINT@129, "  SCORE:"; SC;
930 PRINT@193, " ANY KEY TO RESTART";
940 IF PEEK(14400) = 0 THEN GOTO 940
950 GOTO 100
