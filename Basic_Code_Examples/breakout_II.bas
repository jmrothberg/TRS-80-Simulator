10 REM BREAKOUT - SIMPLE AND WORKING
20 CLS
30 REM INITIALIZE VARIABLES
40 P = 60: REM PADDLE X POSITION
45 OP = P: REM OLD PADDLE POSITION
50 X = 64: Y = 35: REM BALL POSITION
60 DX = 1: DY = -1: REM BALL DIRECTION
70 S = 0: REM SCORE
80 L = 5: REM BALLS LEFT
90 DIM B(80): REM BRICK ARRAY
100 REM INITIALIZE ALL BRICKS
110 FOR I = 1 TO 80: B(I) = 1: NEXT I
120 REM DRAW BRICKS (4 ROWS, CENTERED)
130 FOR R = 0 TO 3
140 FOR C = 0 TO 19
150 BX = 5 + C * 6: BY = 6 + R * 3
160 FOR J = 0 TO 4
170 SET(BX + J, BY): SET(BX + J, BY + 1)
180 NEXT J
190 NEXT C
200 NEXT R
205 REM DRAW INITIAL PADDLE
206 FOR I = 0 TO 7: SET(P + I, 47): NEXT I
210 REM MAIN GAME LOOP
220 REM ERASE OLD BALL
230 RESET(X, Y)
235 REM STORE OLD PADDLE POSITION BEFORE MOVING
236 OP = P
250 REM MOVE BALL
260 X = X + DX: Y = Y + DY
270 REM CHECK WALLS
280 IF X < 3 OR X > 126 THEN DX = -DX
290 IF Y < 3 THEN DY = -DY
300 REM CHECK PADDLE
310 IF Y = 46 AND X >= P AND X <= P + 7 THEN DY = -1
320 REM CHECK BRICK COLLISION
330 IF Y >= 6 AND Y <= 17 THEN GOSUB 500
340 REM CHECK BALL LOST
350 IF Y > 47 THEN GOSUB 700
360 REM CHECK KEYBOARD
370 K$ = INKEY$
380 IF K$ = "A" THEN IF P > 2 THEN P = P - 2
390 IF K$ = "S" THEN IF P < 119 THEN P = P + 2
395 REM ONLY UPDATE PADDLE IF IT MOVED
396 IF P <> OP THEN GOSUB 900
400 REM DRAW BALL
410 SET(X, Y)
430 REM STATUS LINE
440 PRINT@1, "SCORE:"; S; " BALLS:"; L;
450 REM DELAY
460 FOR D = 1 TO 50: NEXT D
470 GOTO 220
500 REM BRICK COLLISION
510 R = INT((Y - 6) / 3)
520 IF R < 0 OR R > 3 THEN RETURN
530 C = INT((X - 5) / 6)
540 IF C < 0 OR C > 19 THEN RETURN
550 I = R * 20 + C + 1
560 IF B(I) = 0 THEN RETURN
570 B(I) = 0
580 BX = 5 + C * 6: BY = 6 + R * 3
590 FOR J = 0 TO 4
600 RESET(BX + J, BY): RESET(BX + J, BY + 1)
610 NEXT J
620 S = S + 10
630 DY = -DY
640 RETURN
700 REM BALL LOST
710 L = L - 1
720 IF L = 0 THEN GOTO 800
730 FOR D = 1 TO 500: NEXT D
740 X = 64: Y = 35: DX = 1: DY = -1
750 RETURN
800 REM GAME OVER
810 CLS
820 PRINT "GAME OVER!"
830 PRINT "FINAL SCORE:"; S
840 END
900 REM UPDATE PADDLE SUBROUTINE
910 REM CLEAR ONLY THE PIXELS THAT NEED CLEARING
920 IF P < OP THEN FOR I = 6 TO 7: RESET(OP + I, 47)
930 IF P < OP THEN NEXT I
940 IF P > OP THEN FOR I = 0 TO 1: RESET(OP + I, 47)
950 IF P > OP THEN NEXT I
960 REM DRAW NEW PADDLE
970 FOR I = 0 TO 7: SET(P + I, 47): NEXT I
980 RETURN


