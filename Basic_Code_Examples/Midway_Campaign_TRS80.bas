13 M$="123456"
20 FOR I=0 TO 5:FOR J=2 TO 7:READ K:F(I,J)=K:NEXT J:NEXT I
30 FOR I=0 TO 5:READ J,K,L:GOSUB 10000:NEXT I
40 FOR I=0 TO 8:FOR J=0 TO 3:READ K:C(I,J)=K:NEXT J:FOR J=4 TO 9:C(I,J)=0:NEXT J:NEXT I
50 FOR I=0 TO 5:READ K:W(I)=K:FX(I)=0:FY(I)=0:FZ(I)=0:NEXT I
60 C(8,7)=C(8,1):C(8,1)=0
70 FOR I=0 TO 9:S(I,9)=-1:NEXT I
80 GOSUB 29000
85 GOSUB 14000:GOSUB 16000:GOSUB 17000
90 REM --- MAIN LOOP ---
200 IF F9=0 THEN 1300
210 PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);
300 PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);:PRINT@ 961,"CMD T/A/L/CA/CL/#/? >";:INPUT A$
301 IF A$="" THEN 1200
310 X=ASC(A$):IF (X>47) AND (X<58) THEN 1210
320 IF A$="T" THEN 600
330 IF A$="A" THEN 700
335 IF A$="L" THEN 1000
340 IF LEN(A$)>=2 THEN IF MID$(A$,1,2)="CA" THEN 900
350 IF LEN(A$)>=2 THEN IF MID$(A$,1,2)="CL" THEN 800
355 IF A$="?" THEN GOSUB 9700:GOTO 80
360 IF A$="H" THEN GOSUB 9700:GOTO 80
370 PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);:PRINT@ 897,"CMDS: T A L CA CL 1-9 ?";:GOTO 300
400 GOTO 300
500 REM --- SELECT CARRIER ---
501 I=0:PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);:PRINT@ 897,"CARRIER E/H/Y/M";:INPUT A$:IF A$="" THEN RETURN
510 X=ASC(A$):I=-(4*(X=69)+5*(X=72)+6*(X=89)+7*(X=77)):IF I=0 THEN RETURN
520 IF C(I,8)<60 THEN RETURN
530 X=I:I=0:PRINT@ 897,LEFT$(B$,64);:PRINT@ 897,"";:GOSUB 20000:PRINT " NOT OPERATIONAL.":RETURN
600 REM --- CHANGE TF COURSE ---
601 PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);:PRINT@ 897,"WHICH TF 16/17";:INPUT A$:IF A$="" THEN 400
610 X=ASC(MID$(A$,LEN(A$),1)):I=X-51:IF (I<>3) AND (I<>4) THEN 400
