630 F(I,4)=J*R1:GOSUB 16000:GOTO 300
700 REM --- ARM STRIKE ---
701 GOSUB 500:IF I=0 THEN 400
710 X=I:IF C(I,4)+C(I,5)+C(I,6)=0 THEN 730
720 PRINT@ 897,LEFT$(B$,64);:PRINT@ 897,"";:GOSUB 20000:PRINT " STRIKE ON DECK ALREADY.":GOTO 400
730 PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);:PRINT@ 897,"F4F,SBD,TBD";:INPUT J,K,L
740 IF J>C(I,1) THEN J=C(I,1)
741 IF K>C(I,2) THEN K=C(I,2)
742 IF L>C(I,3) THEN L=C(I,3)
750 C(I,4)=J:C(I,1)=C(I,1)-J:C(I,5)=K+1000:C(I,2)=C(I,2)-K:C(I,6)=L:C(I,3)=C(I,3)-L
760 GOSUB 21000:GOTO 300
800 REM --- CLEAR DECK ---
801 GOSUB 500:IF I=0 THEN 400
810 GOSUB 10200:GOSUB 21000:GOTO 300
900 REM --- SET CAP ---
901 GOSUB 500:IF I=0 THEN 400
910 PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);:PRINT@ 897,"F4F FOR CAP";:INPUT J:X=I
915 C(X,1)=C(X,1)+C(X,7):C(X,7)=0:IF J>C(X,1) THEN 930
920 C(X,7)=J:C(X,1)=C(X,1)-J:GOTO 960
930 C(X,7)=C(X,1):C(X,1)=0:J=J-C(X,7)
935 IF J<C(X,4) THEN C(X,7)=C(X,7)+J:C(X,4)=C(X,4)-J:GOTO 960
940 C(X,7)=C(X,7)+C(X,4):C(X,4)=0
960 GOSUB 21000:GOTO 300
1000 REM --- LAUNCH STRIKE ---
1001 L=0:FOR K=0 TO 2:IF F(K,2)>0 THEN L=L+1:C1(L)=K
1010 NEXT K:IF L=0 THEN PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);:PRINT@ 897,"NO TARGETS.":GOTO 400
1020 GOSUB 500:IF I=0 THEN 400
1030 IF (C(I,5)+C(I,6)>0) AND (C(I,5)<1000) THEN 1050
1040 X=I:PRINT@ 897,LEFT$(B$,64);:PRINT@ 897,"";:GOSUB 20000:PRINT " NO STRIKE READY.":GOTO 400
1050 J=L:C=L:IF L>1 THEN PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);:PRINT@ 897,"TARGET 1-";C;:INPUT J
1055 IF (J<1) OR (J>C) THEN 400
1060 J=C1(J):X=J:Y=C(I,0):GOSUB 12600:IF R<=200 THEN 1080
1070 PRINT@ 897,LEFT$(B$,64);:PRINT@ 897,INT(R);" NM OUT OF RANGE.";:GOTO 400
1080 L=R*0.3:IF (I=7) OR ((T+L+L>=240) AND (T+L+L<=1140)) THEN 1100
1090 PRINT@ 897,LEFT$(B$,64);:PRINT@ 897,"NO NIGHT LANDINGS.";:GOTO 400
1100 IF (T+L>=240) AND (T+L<=1140) THEN 1120
1110 PRINT@ 897,LEFT$(B$,64);:PRINT@ 897,"NO NIGHT ATTACKS.";:GOTO 400
1120 K=0
1121 IF S(K,9)<0 THEN 1150
1130 K=K+1:IF K<10 THEN 1121
1140 PRINT@ 897,LEFT$(B$,64);:PRINT@ 897,"TOO MANY STRIKES ALOFT.";:GOTO 400
1150 S(K,0)=C(I,4):S(K,2)=C(I,5):S(K,4)=C(I,6):C(I,4)=0:C(I,5)=0:C(I,6)=0:S(K,6)=J:S(K,9)=I
1160 S(K,7)=T+L:S(K,8)=T+L+L:S(K,3)=1:S(K,5)=0
1165 S(K,1)=-((S(K,2)/(S(K,2)+S(K,4)))>RND(0))
1170 X=I:PRINT@ 897,LEFT$(B$,64);:PRINT@ 897,"";:GOSUB 20000:PRINT " STRIKE LAUNCHED!":GOSUB 21000:GOTO 300
1200 REM --- WAIT (ENTER = 0 HRS) ---
1201 A$="0"
1210 REM --- WAIT N HOURS ---
1211 PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);:T0=T+INT(VAL(A$)*60):D0=D-(T0>1440):T0=T0+1440*(D0>D)
1220 FOR I=4 TO 7:C(I,5)=C(I,5)+1000*(C(I,5)>999):NEXT I
1300 REM === IJN/CRUISER PHASE ===
1301 FOR I=3 TO 4:X=I:Y=2:GOSUB 12600:IF R<50 THEN C5=10
1302 NEXT I:F9=0:X=1:Y=5:GOSUB 12600:IF R<15 THEN F(1,5)=0
1303 IF J9<>0 THEN F(1,4)=270*R1:F(1,5)=18
1304 IF (J9>0) OR (C5>9) THEN F(2,5)=25+15*(C7>255):F(2,4)=270*R1
1305 IF C5>9 THEN 1320
1306 X=2:Y=5:GOSUB 12600:IF R>15 THEN 1320
1307 PRINT@ 897,"CRUISERS BOMBARD ";:X=7:F(2,2)=2:C5=C5+1:IF (J9=0) AND (C7<=255) THEN F(2,5)=0
1308 IF C6>0 THEN F9=1:C6=0
1309 N=0:H=0:FOR K=C7 TO 255 STEP 4:R=RND(0):H=H-(R<0.5):N=N-(R<0.1):NEXT K:N=N-H:D8=24:GOSUB 10400
1310 GOSUB 21000
1320 X=5:Y=0:GOSUB 12600:IF R>250 THEN X=0:Y=5:GOSUB 12500:F(0,4)=A
1330 IF R<100 THEN X=5:Y=0:GOSUB 12500:F(0,4)=A
1350 FOR K=6 TO 4 STEP -1:X=0:Y=C(K,0):IF (F(Y,2)>0) AND (C(K,8)<100) THEN GOSUB 12500:F(0,4)=A
1360 NEXT K
1370 IF J9>0 THEN F(0,4)=270*R1
1400 REM === CAP RECYCLE ===
1401 FOR I=0 TO 3:IF (C(I,7)=5) OR (C(I,8)>=60) THEN 1440
1405 C(I,7)=C(I,7)+C(I,1):C(I,1)=0:IF C(I,7)<5 THEN 1420
1410 C(I,1)=C(I,7)-5:C(I,7)=5:GOTO 1440
1420 C(I,7)=C(I,7)+C(I,4):C(I,4)=0:IF C(I,7)>5 THEN C(I,4)=C(I,7)-5:C(I,7)=5
1440 NEXT I
1500 REM === JAPANESE STRIKE PREP ===
1501 S9=0:A9=S9:A8=S9:I=0:IF T>1140 THEN 1700
1510 IF C(I,4)+C(I,5)+C(I,6)>0 THEN I=4:GOTO 1520
1511 I=I+1:IF I<4 THEN 1510
1512 S9=0:GOTO 1590
1520 IF C(I,8)>=60 THEN 1525
1521 X=C(I,0):Y=0:GOSUB 13000:IF E=1 THEN 1530
1525 I=I+1:IF I<8 THEN 1520
1530 IF I<8 THEN 1550
1531 I=4
1532 IF C(I,8)>=100 THEN 1540
1535 X=C(I,0):Y=0:GOSUB 13000:IF E=1 THEN 1542
1540 I=I+1:IF I<8 THEN 1532
1542 IF I<8 THEN 1550
1543 Y=0:X=5:GOSUB 13000:I=-7*(E=1)
1550 S9=C(I,0):IF S9<5 THEN 1590
1560 I=0
1561 IF (S(I,6)<5) OR (S(I,9)=-1) OR (S(I,1)=-1) THEN 1580
1570 S9=0:GOTO 1590
1580 I=I+1:IF I<10 THEN 1561
1590 IF F(3,2)+F(4,2)>0 THEN A9=1
1600 Y=0:X=5:GOSUB 12600:IF R>235 THEN 1620
1610 L=60*R/235:IF (T+L<240) OR (T+L+L>1140) THEN 1620
1615 A8=1:IF C(3,2)<12 THEN A9=1
1620 IF A9=1 THEN A8=0
1700 REM === JAPANESE LAUNCH ===
1701 IF S9<3 THEN 1770
1710 J=0
1720 IF S(J,9)=-1 THEN 1730
1721 J=J+1:IF J<10 THEN 1720
1722 GOTO 1770
1730 S(J,6)=S9:S(J,9)=0:X=0:Y=S9:GOSUB 12600:L=60*R/235:S(J,7)=T+L:S(J,8)=T+L+L:S(J,0)=0:S(J,2)=0:S(J,4)=0
1750 FOR I=0 TO 3:IF C(I,8)>60 THEN 1767
1760 S(J,0)=S(J,0)+C(I,4):S(J,2)=S(J,2)+C(I,5):C(I,4)=0:C(I,5)=0:S(J,4)=S(J,4)+C(I,6):C(I,6)=0
1767 NEXT I:IF S(J,2)+S(J,4)=0 THEN S(J,9)=-1
1768 S(J,3)=1:S(J,5)=0:IF S(J,9)<>-1 THEN S(J,1)=-((S(J,2)/(S(J,2)+S(J,4)))>RND(0))
1770 FOR I=0 TO 3:GOSUB 10200:IF C(I,8)>60 THEN 1830
1775 IF A9=0 THEN 1790
1780 C(I,4)=C(I,1):C(I,5)=C(I,2):C(I,6)=C(I,3):C(I,1)=0:C(I,2)=0:C(I,3)=0:GOTO 1830
1790 IF A8=0 THEN 1820
1800 C(I,4)=INT(C(I,3)*0.5):C(I,5)=INT(C(I,2)*0.5):C(I,1)=C(I,1)-C(I,4):C(I,2)=C(I,2)-C(I,5)
1810 C(I,6)=INT(C(I,3)*0.5):C(I,3)=C(I,3)-C(I,6)
1820 IF S9+A8+A9=0 THEN C(I,7)=C(I,7)+C(I,1):C(I,1)=0
1830 NEXT I
1900 REM === TIME ADVANCE ===
1901 T1=30+INT(30*RND(0)):T=T+T1:IF (T>=T0) AND (D=D0) THEN F9=1
1910 D=D-(T>1440):T=T+1440*(T>1440):IF (T>=T0) AND (D>=D0) THEN F9=1
2000 REM === MOVEMENT ===
2001 FOR I=0 TO 4:F(I,0)=F(I,0)+T1*F(I,5)*SIN(F(I,4))/60
2010 F(I,1)=F(I,1)+T1*F(I,5)*COS(F(I,4))/60:NEXT I
2100 REM === SCOUTING ===
2101 IF (T>1140) OR (T<240) THEN 2220
2110 P=1-2*((T<300) OR ((T>720) AND (T<780))):FOR I=0 TO 2:IF (F(I,2)=2) OR ((C7>=512) AND (I=2)) THEN 2160
2111 IF F(I,5)=0 THEN F(I,5)=2
2115 IF (F(I,2)=1) AND (RND(0)>3*S7) THEN 2160
2120 IF RND(0)>P*S7 AND F(I,2)=0 THEN 2160
2121 F(I,2)=F(I,2)-(F(I,2)<2)
2130 IF RND(0)>3*S7 THEN 2140
2131 F(I,2)=F(I,2)-(F(I,2)<2)
2140 PRINT@ 897,"PBY SPOTS JAPANESE ";:IF F(I,2)=1 THEN PRINT "SHIPS.":GOTO 2159
2150 X=I:GOSUB 23000:PRINT "."
2159 F9=1:GOSUB 17000
2160 NEXT I:IF F(0,2)=2 THEN F(0,3)=2
2170 P=1-((T>720) AND (T<780)):FOR I=3 TO 4:IF F(I,2)=2 THEN 2210
2180 IF RND(0)<P*S6 THEN F(I,2)=1
2185 IF F(I,2)=0 OR RND(0)>3*S6 THEN 2210
2190 PRINT@ 897,"JAP SCOUTS OVER ";:X=I:GOSUB 23000:PRINT "."
2200 F(I,2)=2:F9=1:GOSUB 16000:I=X
2210 NEXT I:GOTO 2300
2220 FOR I=0 TO 4:F(I,2)=0:NEXT I:F(0,3)=1
2300 REM === STRIKE RESOLUTION ===
2301 FOR I=0 TO 5:FU(I)=1:NEXT I:FOR I=0 TO 9:IF (S(I,9)=-1) OR (S(I,7)>T) OR (S(I,1)=-1) THEN 4000
2302 IF S(I,6)=2 AND C7>511 THEN 4000
2310 J=1-(S(I,6)>2):FOR K=0 TO 4 STEP 2
2315 IF S(I,K)=0 THEN S(I,K+1)=-1
2316 IF RND(0)>0.2 THEN 2330
2320 IF S(I,1)=S(I,K+1) THEN S(I,1)=-1
2321 S(I,K+1)=-1
2330 NEXT K:IF J=2 THEN 2360
2335 FOR K=0 TO 4 STEP 2:IF S(I,K)=0 OR S(I,K+1)>-1 THEN 2350
2340 PRINT@ 897,"";:X=S(I,9):GOSUB 20000:X=J:Y=K:PRINT " ";:GOSUB 24000:PRINT " MISS TARGET.":F9=1
2350 NEXT K:PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);
2360 IF (S(I,3)=-1 OR S(I,2)=0) AND (S(I,5)=-1 OR S(I,4)=0) THEN 4000
2365 F(C(S(I,9),0),2)=2:F(S(I,6),2)=2
2370 IF F(0,2)=2 THEN F(0,3)=2
2380 PRINT@ 897,"";:IF J=1 THEN X=S(I,9):GOSUB 20000
2385 IF J=2 THEN PRINT "JAPANESE";
2390 PRINT " STRIKE ATTACKING"
2395 X=S(I,6):GOSUB 23000:PRINT "!":F9=1
2400 K=0:IF S(I,6)=2 THEN 2420
2410 IF S(I,6)=C(K,0) AND C(K,8)<100 THEN 2600
2411 K=K+1:IF K<9 THEN 2410
2420 REM --- NO CAP, DIRECT ATTACK ---
2421 A$="IN":GOSUB 10300:FOR K=4 TO 2 STEP -2:IF S(I,K)=0 OR S(I,K+1)=-1 THEN 2480
2440 PRINT@ 897,"";:PRINT S(I,K);" ";:X=J:Y=K:GOSUB 24000:PRINT " ATTACK ";
2450 E=F(S(I,6),6)*(1+0.25*(K=4)*(1-(J=1))):H=0:N=0:FOR L=1 TO S(I,K):R=RND(0)
2460 H=H-(R<E):N=N-(R<E+E):NEXT L:N=N-H:D8=16:IF (K=4) AND S(I,6)<>5 THEN D8=24:N=0
2470 X=S(I,6):GOSUB 10500
2480 NEXT K
2490 A$="OUT":GOSUB 10300:GOTO 3950
2600 REM --- CAP COMBAT ---
2601 C=0:FOR K=0 TO 8:IF C(K,0)=S(I,6) THEN C=C+C(K,7):C(K,7)=0
2610 NEXT K:IF C=0 THEN 2790
2620 K=-2*(RND(0)>0.5)+2
2630 IF S(I,K+1)=-1 OR S(I,K)=0 THEN K=6-K
2631 IF FU(S(I,6))=0 THEN K=4
2632 IF K=4 THEN FU(S(I,6))=0
2640 IF S(I,K+1)=-1 OR S(I,K)=0 THEN 2781
2650 X=J:Y=K:PRINT@ 897,"CAP ATTACKS ";:GOSUB 24000:PRINT ".":L1=0:IF S(I,1)=S(I,K+1) THEN L1=S(I,0)
2660 IF L1>0 THEN PRINT@ 961,"";:X=J:Y=0:GOSUB 24000:Y=K:PRINT " DEFEND ";:GOSUB 24000:PRINT "."
2680 E=(C*W(J-1))/(L1*W(-(J=1))+S(I,K)*W(K-(J=1))):IF E>0.85 THEN E=0.85
2690 H=0:FOR L=1 TO S(I,K):H=H-(RND(0)<E):NEXT L
2700 PRINT@ 897,"CAP DOWNS ";H;" ";:X=J:Y=K:GOSUB 24000:PRINT ".":S(I,K)=S(I,K)-H:IF L1=0 THEN 2781
2710 PRINT@ 961,"";:X=J:Y=0:GOSUB 24000:PRINT " ATTACK CAP."
2720 E=(L1*W(-(J=1)))/(C*W(J-1)):IF E>0.85 THEN E=0.85
2730 H=0:FOR L=1 TO C:H=H-(RND(0)<E):NEXT L
2740 PRINT@ 897,"";:X=J:Y=0:GOSUB 24000:PRINT " DOWN ";H;" CAP."
2750 C=C-H:IF C=0 THEN 2782
2755 E=0.5*(C*W(J-1))/(L1*W(-(J=1))):IF E>0.85 THEN E=0.85
2760 H=0:FOR L=1 TO L1:H=H-(RND(0)<E):NEXT L:PRINT@ 961,"CAP DOWNS ";H;" ESCORT."
2780 S(I,0)=S(I,0)-H
2781 IF (S(I,3)=-1 OR S(I,2)=0) AND (S(I,5)=-1 OR S(I,4)=0) THEN 2945
2782 PRINT@ 897,LEFT$(B$,64);:PRINT@ 961,LEFT$(B$,64);
2790 REM --- BOMB RUN ---
2791 A$="IN":GOSUB 10300:FOR K=4 TO 2 STEP -2:IF S(I,K)=0 OR S(I,K+1)=-1 THEN 2940
2810 M=0:FOR L=0 TO 8:C(L,9)=0:IF (C(L,8)<100) AND (C(L,0)=S(I,6)) THEN M=M+1
2815 NEXT L
2816 IF M=0 THEN 2940
2820 O=-1:FOR N=1 TO M
2825 O=O+1:IF C(O,0)<>S(I,6) OR C(O,8)>=100 THEN 2825
2830 C(O,9)=INT((S(I,K)+M-N)/M):NEXT N:FOR L=0 TO 8:IF C(L,9)=0 THEN 2930
2840 PRINT@ 897,"";:PRINT C(L,9);" ";:X=J:Y=K:GOSUB 24000:PRINT " ATTACK ";
2860 N=0:H=0:E=0.2-(K=4)*0.6*(J=1):FOR M=1 TO C(L,9):R=RND(0):H=H-(R<E):N=N-(R<E+E):NEXT M
2870 D8=16-8*((K=4) AND (L<>7)):N=-(N-H)*(D8=16):X=L:GOSUB 10400:GOSUB 21000
2930 NEXT L
2940 NEXT K:A$="OUT":GOSUB 10300
2945 IF C=0 THEN 3950
2950 M=0:FOR L=0 TO 8:C(L,9)=0:IF (C(L,8)<=60) AND (C(L,0)=S(I,6)) THEN M=M+1
2955 NEXT L
2960 IF M=0 THEN PRINT@ 897,"";:X=S(I,6):GOSUB 23000:PRINT " CAP SPLASHES.":GOTO 3950
2970 O=-1:FOR N=1 TO M
2980 O=O+1:IF C(O,0)=S(I,6) AND C(O,8)<=60 THEN C(O,7)=INT((C+M-N)/M):GOTO 2990
2985 GOTO 2980
2990 NEXT N
3950 FOR K=1 TO 5 STEP 2:S(I,K)=-1:NEXT K:GOSUB 21000
4000 NEXT I
4100 REM === RANDOM EXPLOSIONS ===
4101 FOR L=0 TO 8:IF C(L,8)<10 OR C(L,8)>=100 THEN 4150
4110 IF RND(0)>0.5*(1-(L<4)) THEN 4130
4120 X=L:PRINT@ 897,"EXPLOSION ON ";:D8=12:K=2:N=0:H=1:GOSUB 10400:GOSUB 21000
4130 IF C(L,8)>=100 OR RND(0)>0.2*(1-((L>3) AND (L<8))) THEN 4150
4140 C(L,8)=C(L,8)-5*RND(0):IF C(L,8)<0 THEN C(L,8)=0
