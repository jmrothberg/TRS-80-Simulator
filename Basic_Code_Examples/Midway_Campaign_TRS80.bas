1 REM MIDWAY CAMPAIGN - TRS-80 LEVEL II
2 REM ORIGINAL 1980 MICROCOMPUTER GAMES
3 REM FAITHFUL PORT FROM ATARI 8-BIT
4 REM 64x16 SCREEN, PRINT@ 1-1024
5 R1=0.0174533
6 DIM F(5,7):DIM C(8,9):DIM S(9,9):DIM W(5)
7 DIM FU(5):DIM FX(5):DIM FY(5):DIM FZ(5)
8 DIM C1(3):DIM A$(30):DIM M$(6):DIM B$(64)
11 B$="                                                                "
