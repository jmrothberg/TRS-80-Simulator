5000 REM === STRIKE LANDINGS ===
5001 FOR J=0 TO 9:IF S(J,9)=-1 THEN 5220
5005 IF T<S(J,8) THEN 5220
5006 IF S(J,9)<4 THEN 5120
5010 F9=1:I=S(J,9):IF C(I,8)>60 THEN 5050
5020 PRINT@ 897,"STRIKE LANDING ON ";:X=I:GOSUB 20000:PRINT ".":GOSUB 10200:C(I,1)=C(I,1)+S(J,0)
5030 C(I,2)=C(I,2)+S(J,2):C(I,3)=C(I,3)+S(J,4):GOSUB 21000:GOTO 5210
5050 IF I>5 OR (C(4,8)>60 AND C(5,8)>60) THEN K=3:GOTO 5060
5055 K=4+(I=4):GOTO 5100
5060 K=K+1:IF C(K,8)>60 THEN 5070
5065 X=C(I,0):Y=C(K,0):GOSUB 12600:IF R/100<RND(0) THEN 5100
5070 IF K<7 THEN 5060
5080 X=I:PRINT@ 897,"";:GOSUB 20000:PRINT " STRIKE SPLASHES!":GOTO 5210
5100 X=I:PRINT@ 897,"";:GOSUB 20000:PRINT " DIVERTED TO ";:I=K:X=I:GOSUB 20000:PRINT:GOTO 5020
5120 L=0:FOR I=0 TO 3:GOSUB 10200:L=L-(C(I,8)<=60):NEXT I:IF L=0 THEN 5210
5130 FOR K=0 TO 4 STEP 2:M=-1:FOR I=1 TO L
5140 M=M+1:IF C(M,8)>=60 THEN 5140
5150 C(M,1+K/2)=C(M,1+K/2)+INT((L+S(J,K)-I)/L):NEXT I:NEXT K:FOR I=0 TO 3
5160 IF C(I,1)+C(I,2)+C(I,3)<96 THEN 5180
